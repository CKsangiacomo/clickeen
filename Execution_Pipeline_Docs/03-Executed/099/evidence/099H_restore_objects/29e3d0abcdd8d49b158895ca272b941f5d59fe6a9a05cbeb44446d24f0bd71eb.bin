  "textPack": {
    "cta.label": "Kontakt oss",
    "header.subtitleHtml": "Moderne widgeter for nettsider – raske å lansere, enkle å tilpasse og laget for å hjelpe deg å konvertere.",
    "header.title": "Vanlige spørsmål",
    "sections.0.faqs.0.answer": "Clickeen er en widget-SaaS-plattform som lar deg legge til gjennomarbeidede, høytytende widgeter på nettstedet ditt på få minutter – uten tungt utviklingsarbeid.",
    "sections.0.faqs.0.question": "Hva er Clickeen?",
    "sections.0.faqs.1.answer": "Ja. Gratisplanen inkluderer 1 aktiv widget med de viktigste funksjonene, slik at du kan teste Clickeen på et live nettsted.",
    "sections.0.faqs.1.question": "Tilbyr dere en gratisplan?",
    "sections.0.faqs.2.answer": "Opprett widgeten din, kopier innbyggingskoden og lim den inn rett før den avsluttende </body>-taggen på nettstedet ditt. Endringer du gjør i Clickeen, oppdateres umiddelbart.",
    "sections.0.faqs.2.question": "Hvordan installerer jeg en widget på nettstedet mitt?",
    "sections.0.faqs.3.answer": "Lanser raskere med fleksible designkontroller, enkle oppdateringer og stabil ytelse – slik at teamet ditt kan levere forbedringer uten å vedlikeholde egen kode.",
    "sections.0.faqs.3.question": "Hvorfor bruke Clickeen i stedet for å bygge widgeter fra bunnen av?",
    "sections.0.title": "Kom i gang"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
