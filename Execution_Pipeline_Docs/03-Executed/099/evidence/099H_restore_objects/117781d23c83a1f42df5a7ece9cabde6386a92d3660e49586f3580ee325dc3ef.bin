{
  "excerptHtml": "<section class=\"ck-excerpt ck-excerpt--faq\" data-ck-excerpt=\"faq\" data-ck-locale=\"hu\">\n    <h2 class=\"ck-excerpt__title\">Frequently Asked Questions</h2>\n    <dl class=\"ck-excerpt__list\">\n      \n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What types of art exhibits are available?</dt>\n        <dd class=\"ck-excerpt__a\">We offer a variety of modern art exhibits including contemporary artists , sculptures, and installations .</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What are the visiting hours?</dt>\n        <dd class=\"ck-excerpt__a\">The museum is open daily from 10 AM to 6 PM.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Is there an age restriction?</dt>\n        <dd class=\"ck-excerpt__a\">No, all ages are welcome.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Do you offer any special packages?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, we offer group discounts and special event packages.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What is your cancellation policy?</dt>\n        <dd class=\"ck-excerpt__a\">Cancellations must be made 24 hours in advance to avoid a fee.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Do you offer any educational programs?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, we offer educational tours and programs for schools and groups.</dd>\n      </div>\n    </dl>\n  </section>",
  "schemaJsonLd": "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"inLanguage\":\"hu\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What types of art exhibits are available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We offer a variety of modern art exhibits including contemporary artists , sculptures, and installations .\"}},{\"@type\":\"Question\",\"name\":\"What are the visiting hours?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The museum is open daily from 10 AM to 6 PM.\"}},{\"@type\":\"Question\",\"name\":\"Is there an age restriction?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"No, all ages are welcome.\"}},{\"@type\":\"Question\",\"name\":\"Do you offer any special packages?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, we offer group discounts and special event packages.\"}},{\"@type\":\"Question\",\"name\":\"What is your cancellation policy?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Cancellations must be made 24 hours in advance to avoid a fee.\"}},{\"@type\":\"Question\",\"name\":\"Do you offer any educational programs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, we offer educational tours and programs for schools and groups.\"}}]}]}"
}