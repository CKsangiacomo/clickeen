  "textPack": {
    "cta.label": "Kontakt os",
    "header.subtitleHtml": "Moderne website-widgets—hurtige at lancere, nemme at tilpasse og bygget til at hjælpe dig med at konvertere.",
    "header.title": "Ofte stillede spørgsmål",
    "sections.0.faqs.0.answer": "Clickeen er en widget-SaaS-platform, der lader dig tilføje gennemarbejdede widgets med høj performance til dit website på få minutter—uden tungt udviklingsarbejde.",
    "sections.0.faqs.0.question": "Hvad er Clickeen?",
    "sections.0.faqs.1.answer": "Ja. Free-planen inkluderer 1 aktiv widget med de vigtigste funktioner, så du kan prøve Clickeen på et live website.",
    "sections.0.faqs.1.question": "Tilbyder I en gratis plan?",
    "sections.0.faqs.2.answer": "Opret din widget, kopiér embed-koden, og indsæt den lige før det afsluttende </body>-tag på dit website. Ændringer, du laver i Clickeen, opdateres med det samme.",
    "sections.0.faqs.2.question": "Hvordan installerer jeg en widget på mit website?",
    "sections.0.faqs.3.answer": "Lancér hurtigere med fleksible designkontroller, enkle opdateringer og stabil performance—så dit team kan levere forbedringer uden at vedligeholde custom kode.",
    "sections.0.faqs.3.question": "Hvorfor bruge Clickeen i stedet for at bygge widgets fra bunden?",
    "sections.0.title": "Kom i gang"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
