  "textPack": {
    "cta.label": "Nous contacter",
    "header.subtitleHtml": "Des widgets de site modernes — rapides à mettre en ligne, faciles à personnaliser et conçus pour vous aider à convertir.",
    "header.title": "FAQ",
    "sections.0.faqs.0.answer": "Clickeen est une plateforme SaaS de widgets qui vous permet d’ajouter à votre site des widgets soignés et performants en quelques minutes — sans gros travail de développement.",
    "sections.0.faqs.0.question": "Qu’est-ce que Clickeen ?",
    "sections.0.faqs.1.answer": "Oui. L’offre Free inclut 1 widget actif avec les fonctionnalités essentielles, pour que vous puissiez tester Clickeen sur un site en production.",
    "sections.0.faqs.1.question": "Proposez-vous une offre gratuite ?",
    "sections.0.faqs.2.answer": "Créez votre widget, copiez le code d’intégration, puis collez-le juste avant la balise de fermeture </body> sur votre site. Les modifications effectuées dans Clickeen sont mises à jour instantanément.",
    "sections.0.faqs.2.question": "Comment installer un widget sur mon site ?",
    "sections.0.faqs.3.answer": "Lancez plus vite grâce à des options de design flexibles, des mises à jour simples et des performances fiables — pour que votre équipe puisse livrer des améliorations sans maintenir de code sur mesure.",
    "sections.0.faqs.3.question": "Pourquoi utiliser Clickeen plutôt que de créer des widgets de zéro ?",
    "sections.0.title": "Bien démarrer"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
