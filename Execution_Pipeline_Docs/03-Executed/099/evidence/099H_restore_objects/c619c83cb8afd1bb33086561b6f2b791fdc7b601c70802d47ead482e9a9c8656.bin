          "defaultOpen": false,
          "id": "89cc1b7e-73b8-44ac-aeb3-7a6667387e94",
          "question": "Do you offer any special packages?"
        },
        {
          "answer": "Cancellations must be made 24 hours in advance to avoid a fee.",
          "defaultOpen": false,
