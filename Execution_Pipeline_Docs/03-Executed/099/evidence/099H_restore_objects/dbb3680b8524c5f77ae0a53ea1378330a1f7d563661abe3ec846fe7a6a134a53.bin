  "textPack": {
    "cta.label": "Neem contact op",
    "header.subtitleHtml": "Moderne websitewidgets—snel te lanceren, eenvoudig aan te passen en gemaakt om je conversie te verhogen.",
    "header.title": "Veelgestelde vragen",
    "sections.0.faqs.0.answer": "Clickeen is een widget-SaaS-platform waarmee je in enkele minuten strak vormgegeven, goed presterende widgets aan je website toevoegt—zonder zware development.",
    "sections.0.faqs.0.question": "Wat is Clickeen?",
    "sections.0.faqs.1.answer": "Ja. Het Free-plan bevat 1 actieve widget met essentiële functies, zodat je Clickeen kunt uitproberen op een live site.",
    "sections.0.faqs.1.question": "Bieden jullie een gratis plan aan?",
    "sections.0.faqs.2.answer": "Maak je widget, kopieer de embedcode en plak deze vlak vóór de afsluitende </body>-tag op je website. Wijzigingen die je in Clickeen maakt, worden direct bijgewerkt.",
    "sections.0.faqs.2.question": "Hoe installeer ik een widget op mijn site?",
    "sections.0.faqs.3.answer": "Ga sneller live met flexibele ontwerpopties, eenvoudige updates en betrouwbare performance—zodat je team verbeteringen kan uitrollen zonder custom code te onderhouden.",
    "sections.0.faqs.3.question": "Waarom Clickeen gebruiken in plaats van widgets vanaf nul te bouwen?",
    "sections.0.title": "Aan de slag"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
