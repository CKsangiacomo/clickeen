  "textPack": {
    "cta.label": "संपर्क करें",
    "header.subtitleHtml": "आधुनिक वेबसाइट विजेट—तेज़ी से लॉन्च करें, आसानी से कस्टमाइज़ करें, और कन्वर्ज़न बढ़ाने के लिए बनाए गए।",
    "header.title": "अक्सर पूछे जाने वाले सवाल",
    "sections.0.faqs.0.answer": "Clickeen एक widget SaaS प्लेटफ़ॉर्म है जो आपको मिनटों में अपनी वेबसाइट पर पॉलिश्ड, हाई-परफ़ॉर्मिंग विजेट जोड़ने देता है—बिना भारी dev काम के।",
    "sections.0.faqs.0.question": "Clickeen क्या है?",
    "sections.0.faqs.1.answer": "हाँ। Free प्लान में 1 एक्टिव विजेट और ज़रूरी फीचर्स शामिल हैं, ताकि आप Clickeen को लाइव साइट पर आज़मा सकें।",
    "sections.0.faqs.1.question": "क्या आपके पास कोई मुफ़्त प्लान है?",
    "sections.0.faqs.2.answer": "अपना विजेट बनाएँ, embed code कॉपी करें, और उसे अपनी वेबसाइट पर क्लोज़िंग </body> टैग से ठीक पहले पेस्ट करें। Clickeen में किए गए बदलाव तुरंत अपडेट हो जाते हैं।",
    "sections.0.faqs.2.question": "मैं अपनी साइट पर विजेट कैसे इंस्टॉल करूँ?",
    "sections.0.faqs.3.answer": "लचीले डिज़ाइन कंट्रोल, आसान अपडेट्स, और भरोसेमंद परफ़ॉर्मेंस के साथ जल्दी लॉन्च करें—ताकि आपकी टीम custom code को मेंटेन किए बिना सुधार रिलीज़ कर सके।",
    "sections.0.faqs.3.question": "विजेट्स को शुरू से बनाने के बजाय Clickeen क्यों इस्तेमाल करें?",
    "sections.0.title": "शुरुआत करें"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
