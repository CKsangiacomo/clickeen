  "type": "grid",
  "typeConfig": {
    "carousel": {
      "allowSwipe": true,
      "autoSlideDelayMs": 2500,
      "autoplay": false,
      "direction": "left",
      "mode": "paged",
      "pauseOnHover": true,
      "showArrows": true,
      "speed": 30,
      "step": "page",
      "transitionMs": 350
    },
    "grid": {}
  },
  "typography": {
    "globalFamily": "Inter",
    "roleScales": {
      "body": {
        "l": "16px",
        "m": "14px",
        "s": "13px",
        "xl": "18px",
        "xs": "12px"
      },
      "title": {
        "l": "28px",
        "m": "24px",
        "s": "20px",
        "xl": "32px",
        "xs": "18px"
      }
    },
    "roles": {
      "body": {
        "color": "color-mix(in oklab, var(--color-system-black), transparent 25%)",
        "family": "Inter",
        "fontStyle": "normal",
        "sizeCustom": "14px",
        "sizePreset": "m",
        "weight": "400"
      },
      "title": {
        "color": "var(--color-system-black)",
        "family": "Inter",
        "fontStyle": "normal",
        "sizeCustom": "24px",
        "sizePreset": "m",
        "weight": "700"
      }
    }
