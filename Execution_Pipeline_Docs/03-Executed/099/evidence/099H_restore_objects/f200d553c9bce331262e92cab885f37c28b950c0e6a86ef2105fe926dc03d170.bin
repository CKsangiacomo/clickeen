{
  "appearance": {
    "ctaBackground": "var(--color-system-blue)",
    "ctaRadius": "md",
    "ctaTextColor": "var(--color-system-white)",
    "itemBackground": "transparent",
    "itemCard": {
      "border": {
        "color": "color-mix(in oklab, var(--color-system-black), transparent 88%)",
        "enabled": false,
        "width": 1
      },
      "radius": "4xl",
      "radiusBL": "4xl",
      "radiusBR": "4xl",
      "radiusLinked": true,
      "radiusTL": "4xl",
      "radiusTR": "4xl",
      "shadow": {
        "alpha": 18,
        "blur": 24,
        "color": "#000000",
        "enabled": false,
        "inset": false,
        "spread": 0,
        "x": 0,
        "y": 8
      }
    },
    "logoLook": "original",
    "logoOpacity": 0.9,
    "textColor": "color-mix(in oklab, var(--color-system-black), transparent 25%)",
    "titleColor": "var(--color-system-black)"
  },
  "behavior": {
    "randomOrder": false,
    "showBacklink": true
  },
  "cta": {
    "enabled": true,
    "href": "https://example.com/contact",
    "label": "Contact us",
    "style": "filled"
  },
  "header": {
    "alignment": "center",
    "enabled": true,
    "textHtml": "Trusted by teams worldwide.",
    "title": "Some of our best clients"
  },
  "pod": {
    "background": "var(--color-system-white)",
    "contentWidth": 960,
    "padding": {
      "desktop": {
        "all": 24,
        "bottom": 24,
        "left": 24,
        "linked": true,
        "right": 24,
        "top": 24
      },
      "mobile": {
        "all": 16,
        "bottom": 16,
        "left": 16,
        "linked": true,
        "right": 16,
        "top": 16
      }
    },
    "radius": "4xl",
    "radiusBL": "4xl",
    "radiusBR": "4xl",
    "radiusLinked": true,
    "radiusTL": "4xl",
    "radiusTR": "4xl",
    "shadow": {
      "alpha": 18,
      "blur": 24,
      "color": "#000000",
      "enabled": false,
      "inset": false,
      "spread": 0,
      "x": 0,
      "y": 8
    },
    "widthMode": "fixed"
  },
  "seoGeo": {
    "enabled": false
  },
  "spacing": {
    "gap": 20,
    "logoHeight": 40,
    "mobileGap": 16,
    "mobileStripGap": 12,
    "rowGap": 16,
    "stripGap": 16
  },
  "stage": {
    "alignment": "center",
    "background": "var(--color-system-gray-5)",
    "canvas": {
      "height": 0,
      "mode": "viewport",
      "width": 0
    },
    "padding": {
      "desktop": {
        "all": 80,
        "bottom": 80,
        "left": 80,
        "linked": true,
        "right": 80,
        "top": 80
      },
      "mobile": {
        "all": 24,
        "bottom": 24,
        "left": 24,
        "linked": true,
        "right": 24,
        "top": 24
      }
    }
  },
