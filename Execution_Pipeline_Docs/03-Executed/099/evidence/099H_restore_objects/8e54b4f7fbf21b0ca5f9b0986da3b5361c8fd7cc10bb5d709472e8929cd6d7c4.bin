      "faqs": [
        {
          "answer": "We feature contemporary art from <a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\">local</a> and i<a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\"></a><a href=\"https://www.clickeen.com/\" class=\"diet-dropdown-edit-link\">nternational artists</a> .",
          "defaultOpen": false,
          "id": "q1",
          "question": "What types of art are displayed?"
        },
        {
          "answer": "The gallery is open Tuesday to Sunday from 10 AM to 6 PM.",
          "defaultOpen": false,
          "id": "q3",
          "question": "What are the gallery hours?"
        },
        {
          "answer": "Admission is free, but donations are appreciated.",
          "defaultOpen": false,
          "id": "q2",
          "question": "Is there an admission fee?"
        },
        {
          "answer": "Yes, you can purchase art directly from the gallery.",
          "defaultOpen": false,
          "id": "89cc1b7e-73b8-44ac-aeb3-7a6667387e94",
          "question": "Can I purchase art at the gallery?"
        },
        {
          "answer": "Check our website for information on upcoming exhibitions and events.",
          "defaultOpen": false,
          "id": "q4",
          "question": "Are there any upcoming events?"
        },
        {
          "answer": "Yes, we offer private event hosting for a fee.",
          "defaultOpen": false,
          "id": "q5",
          "question": "Can I host a private event at the gallery?"
        }
      ],
