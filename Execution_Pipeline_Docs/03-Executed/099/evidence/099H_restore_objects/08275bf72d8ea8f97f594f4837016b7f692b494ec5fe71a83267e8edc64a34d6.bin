{
  "excerptHtml": "<section class=\"ck-excerpt ck-excerpt--faq\" data-ck-excerpt=\"faq\" data-ck-locale=\"da\">\n    <h2 class=\"ck-excerpt__title\">Frequently Asked Questions</h2>\n    <dl class=\"ck-excerpt__list\">\n      \n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What types of art are displayed?</dt>\n        <dd class=\"ck-excerpt__a\">We feature contemporary art from local and i nternational artists .</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What are the gallery hours?</dt>\n        <dd class=\"ck-excerpt__a\">The gallery is open Tuesday to Sunday from 10 AM to 6 PM.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Is there an admission fee?</dt>\n        <dd class=\"ck-excerpt__a\">Admission is free, but donations are appreciated.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Can I purchase art at the gallery?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, you can purchase art directly from the gallery.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Are there any upcoming events?</dt>\n        <dd class=\"ck-excerpt__a\">Check our website for information on upcoming exhibitions and events.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Can I host a private event at the gallery?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, we offer private event hosting for a fee.</dd>\n      </div>\n    </dl>\n  </section>",
  "schemaJsonLd": "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"inLanguage\":\"da\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What types of art are displayed?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We feature contemporary art from local and i nternational artists .\"}},{\"@type\":\"Question\",\"name\":\"What are the gallery hours?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The gallery is open Tuesday to Sunday from 10 AM to 6 PM.\"}},{\"@type\":\"Question\",\"name\":\"Is there an admission fee?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Admission is free, but donations are appreciated.\"}},{\"@type\":\"Question\",\"name\":\"Can I purchase art at the gallery?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, you can purchase art directly from the gallery.\"}},{\"@type\":\"Question\",\"name\":\"Are there any upcoming events?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Check our website for information on upcoming exhibitions and events.\"}},{\"@type\":\"Question\",\"name\":\"Can I host a private event at the gallery?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, we offer private event hosting for a fee.\"}}]}]}"
}