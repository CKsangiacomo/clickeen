{
  "excerptHtml": "<section class=\"ck-excerpt ck-excerpt--faq\" data-ck-excerpt=\"faq\" data-ck-locale=\"da\">\n    <h2 class=\"ck-excerpt__title\">Frequently Asked Questions</h2>\n    <dl class=\"ck-excerpt__list\">\n      \n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What is Ive Engineering?</dt>\n        <dd class=\"ck-excerpt__a\">Ive Engineering is a global firm specializing in innovative engineering solutions and services.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">How do I start using Ive Engineering&#39;s services?</dt>\n        <dd class=\"ck-excerpt__a\">Simply reach out to us, discuss your project needs, and we&#39;ll guide you through our service offerings.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Is there a consultation available?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, Ive Engineering offers free consultations to understand your project requirements better.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Why should I choose Ive Engineering for my engineering needs?</dt>\n        <dd class=\"ck-excerpt__a\">Ive Engineering provides cutting-edge solutions, experienced professionals, and tailored services to meet your specific engineering needs.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What are the core values of Ive Engineering?</dt>\n        <dd class=\"ck-excerpt__a\">Ive Engineering values innovation, integrity, and excellence in all its projects and services.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">How can I get in touch with Ive Engineering?</dt>\n        <dd class=\"ck-excerpt__a\">You can contact Ive Engineering through our website, email, or phone number provided on our contact page.</dd>\n      </div>\n    </dl>\n  </section>",
  "schemaJsonLd": "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"inLanguage\":\"da\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is Ive Engineering?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ive Engineering is a global firm specializing in innovative engineering solutions and services.\"}},{\"@type\":\"Question\",\"name\":\"How do I start using Ive Engineering's services?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Simply reach out to us, discuss your project needs, and we'll guide you through our service offerings.\"}},{\"@type\":\"Question\",\"name\":\"Is there a consultation available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Ive Engineering offers free consultations to understand your project requirements better.\"}},{\"@type\":\"Question\",\"name\":\"Why should I choose Ive Engineering for my engineering needs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ive Engineering provides cutting-edge solutions, experienced professionals, and tailored services to meet your specific engineering needs.\"}},{\"@type\":\"Question\",\"name\":\"What are the core values of Ive Engineering?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Ive Engineering values innovation, integrity, and excellence in all its projects and services.\"}},{\"@type\":\"Question\",\"name\":\"How can I get in touch with Ive Engineering?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"You can contact Ive Engineering through our website, email, or phone number provided on our contact page.\"}}]}]}"
}