{
  "excerptHtml": "<section class=\"ck-excerpt ck-excerpt--faq\" data-ck-excerpt=\"faq\" data-ck-locale=\"zh-tw\">\n    <h2 class=\"ck-excerpt__title\">Frequently Asked Questions</h2>\n    <dl class=\"ck-excerpt__list\">\n      \n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What types of rooms are available?</dt>\n        <dd class=\"ck-excerpt__a\">We offer a variety of rooms including standard , deluxe , and suites .</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What are the check-in and check-out times?</dt>\n        <dd class=\"ck-excerpt__a\">Check-in is at 3 PM and check-out is by 11 AM.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Is breakfast included?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, a complimentary breakfast is included with your stay.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Do you offer any special packages?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, we offer romantic getaway packages and family-friendly options.</dd>\n      </div>\n    </dl>\n  </section>",
  "schemaJsonLd": "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"inLanguage\":\"zh-tw\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What types of rooms are available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"We offer a variety of rooms including standard , deluxe , and suites .\"}},{\"@type\":\"Question\",\"name\":\"What are the check-in and check-out times?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Check-in is at 3 PM and check-out is by 11 AM.\"}},{\"@type\":\"Question\",\"name\":\"Is breakfast included?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, a complimentary breakfast is included with your stay.\"}},{\"@type\":\"Question\",\"name\":\"Do you offer any special packages?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, we offer romantic getaway packages and family-friendly options.\"}}]}]}"
