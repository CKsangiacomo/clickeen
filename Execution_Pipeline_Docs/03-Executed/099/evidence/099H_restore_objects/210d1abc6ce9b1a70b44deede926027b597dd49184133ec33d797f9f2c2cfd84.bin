  "baseFingerprint": "bd8901ae935f09dc57fa58f3054e644bcaa498d7a0e79002f4c330771e7f50be",
  "status": "ready",
  "ops": [],
  "textPack": {
    "cta.label": "Ota yhteyttä",
    "header.subtitleHtml": "Modernit verkkosivuwidgetit – nopea ottaa käyttöön, helppo muokata ja suunniteltu parantamaan konversiota.",
    "header.title": "UKK",
    "sections.0.faqs.0.answer": "Clickeen on widget-SaaS-alusta, jonka avulla lisäät viimeistellyt ja suorituskykyiset widgetit sivustollesi minuuteissa – ilman raskasta kehitystyötä.",
    "sections.0.faqs.0.question": "Mikä Clickeen on?",
    "sections.0.faqs.1.answer": "Kyllä. Free-pakettiin sisältyy 1 aktiivinen widget sekä olennaiset ominaisuudet, jotta voit kokeilla Clickeeniä tuotantosivustolla.",
    "sections.0.faqs.1.question": "Onko teillä ilmainen paketti?",
    "sections.0.faqs.2.answer": "Luo widget, kopioi upotuskoodi ja liitä se sivustollesi juuri ennen sulkevaa </body>-tagia. Clickeenissä tekemäsi muutokset päivittyvät heti.",
    "sections.0.faqs.2.question": "Miten asennan widgetin sivustolleni?",
    "sections.0.faqs.3.answer": "Julkaise nopeammin joustavilla design-säädöillä, helpoilla päivityksillä ja luotettavalla suorituskyvyllä – jotta tiimisi voi toimittaa parannuksia ilman oman koodin ylläpitoa.",
    "sections.0.faqs.3.question": "Miksi käyttää Clickeeniä sen sijaan, että rakentaisi widgetit alusta asti?",
    "sections.0.title": "Aloitus"
  },
  "updatedAt": "2026-03-23T18:57:29.518Z"
}
