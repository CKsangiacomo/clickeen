{
  "excerptHtml": "<section class=\"ck-excerpt ck-excerpt--faq\" data-ck-excerpt=\"faq\" data-ck-locale=\"fil\">\n    <h2 class=\"ck-excerpt__title\">Frequently Asked Questions</h2>\n    <dl class=\"ck-excerpt__list\">\n      \n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">What is Liquid Marketing?</dt>\n        <dd class=\"ck-excerpt__a\">Liquid Marketing is a SaaS company that specializes in marketing automation, offering advanced tools for email campaigns, customer segmentation, and analytics.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">How do I start using Liquid Marketing?</dt>\n        <dd class=\"ck-excerpt__a\">Simply sign up, integrate your data, and start creating automated campaigns with our intuitive platform.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Is there a free trial available?</dt>\n        <dd class=\"ck-excerpt__a\">Yes, Liquid Marketing offers a free trial with access to basic features. Upgrade for more advanced capabilities.</dd>\n      </div>\n      <div class=\"ck-excerpt__item\">\n        <dt class=\"ck-excerpt__q\">Why should I choose Liquid Marketing for my marketing needs?</dt>\n        <dd class=\"ck-excerpt__a\">Liquid Marketing provides a robust platform with easy-to-use automation tools, detailed analytics, and excellent customer support, making it ideal for businesses looking to streamline their marketing efforts.</dd>\n      </div>\n    </dl>\n  </section>",
  "schemaJsonLd": "{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"FAQPage\",\"inLanguage\":\"fil\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is Liquid Marketing?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Liquid Marketing is a SaaS company that specializes in marketing automation, offering advanced tools for email campaigns, customer segmentation, and analytics.\"}},{\"@type\":\"Question\",\"name\":\"How do I start using Liquid Marketing?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Simply sign up, integrate your data, and start creating automated campaigns with our intuitive platform.\"}},{\"@type\":\"Question\",\"name\":\"Is there a free trial available?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, Liquid Marketing offers a free trial with access to basic features. Upgrade for more advanced capabilities.\"}},{\"@type\":\"Question\",\"name\":\"Why should I choose Liquid Marketing for my marketing needs?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Liquid Marketing provides a robust platform with easy-to-use automation tools, detailed analytics, and excellent customer support, making it ideal for businesses looking to streamline their marketing efforts.\"}}]}]}"
}