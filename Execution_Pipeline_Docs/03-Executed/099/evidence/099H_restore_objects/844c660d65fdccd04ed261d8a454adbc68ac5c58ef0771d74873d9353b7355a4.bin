  "sections": [
    {
      "faqs": [
        {
          "answer": "Clickeen is a widget SaaS platform that lets you add polished, high-performing widgets to your website in minutes—no heavy dev work required.",
          "defaultOpen": false,
          "id": "q1",
          "question": "What is Clickeen?"
        },
        {
          "answer": "Yes. The Free plan includes 1 active widget with essential features so you can try Clickeen on a live site.",
          "defaultOpen": false,
          "id": "q2",
          "question": "Do you offer a free plan?"
        },
        {
          "answer": "Create your widget, copy the embed code, and paste it right before the closing </body> tag on your website. Changes you make in Clickeen update instantly.",
          "defaultOpen": false,
          "id": "q3",
          "question": "How do I install a widget on my site?"
        },
        {
          "answer": "Launch faster with flexible design controls, simple updates, and reliable performance—so your team can ship improvements without maintaining custom code.",
          "defaultOpen": false,
          "id": "89cc1b7e-73b8-44ac-aeb3-7a6667387e94",
          "question": "Why use Clickeen instead of building widgets from scratch?"
        }
      ],
      "id": "s1",
      "title": "Getting started"
    }
