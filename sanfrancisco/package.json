{
  "name": "@clickeen/sanfrancisco",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "deploy": "node ../scripts/infra/ensure-queues.mjs --write --queues sanfrancisco-events-dev && wrangler deploy",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "rm -rf /tmp/clickeen-sanfrancisco-tests && esbuild src/l10n-account-routes.test.ts --bundle --platform=node --format=esm --external:cloudflare:workers --outdir=/tmp/clickeen-sanfrancisco-tests && node --test /tmp/clickeen-sanfrancisco-tests/l10n-account-routes.test.js"
  },
  "dependencies": {
    "@clickeen/ck-contracts": "workspace:*",
    "@clickeen/ck-policy": "workspace:*",
    "@clickeen/l10n": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251228.0",
    "wrangler": "^4.54.0"
  }
}
