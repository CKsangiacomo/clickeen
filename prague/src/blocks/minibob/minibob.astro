---
import { assertPrimitives } from '../../composition/index';
import PrimitiveRenderer from '../../composition/renderers/astro/PrimitiveRenderer.astro';
import InstanceEmbed from '../../components/InstanceEmbed.astro';

type Props = {
  widget: string;
  locale: string;
  page: string;
  heading: string;
  subhead: string;
};

const { widget, locale, heading, subhead } = Astro.props;

const headerPrimitives = assertPrimitives(
  [
    {
      type: 'heading',
      level: 2,
      content: heading,
      className: 'display-2 ck-m0 ck-minibobStage__title',
    },
    {
      type: 'text',
      variant: 'body',
      content: subhead,
      className: 'body-website ck-m0 ck-minibobStage__subhead ck-text-secondary',
    },
  ],
  'minibob.header',
);

const publicId = `wgt_main_${widget}`;
const createHref = (() => {
  try {
    const parts = Astro.url.pathname.split('/').filter(Boolean);
    const marketKey = parts[0] || 'us';
    const localeKey = parts[1] || locale || 'en';
    return `/${marketKey}/${localeKey}/create`;
  } catch {
    return `/${locale || 'en'}/create`;
  }
})();
---

<section id="minibob" class="ck-canvas">
  <div class="ck-minibobStage ck-stack ck-gap-tight">
    <PrimitiveRenderer primitives={headerPrimitives} />
    <div class="ck-minibobStage__actions">
      <a class="ck-btn ck-btn--md label-s" href={createHref}>
        Create free account
      </a>
    </div>
  </div>

  <div class="ck-inline">
    <div class="ck-minibob__embed">
      <InstanceEmbed
        publicId={publicId}
        locale={locale}
        title="Demo widget preview"
        loading="eager"
        showShareChrome={false}
      />
    </div>
  </div>
</section>

<style>
  #minibob.ck-canvas {
    background: var(--color-system-white);
  }

  .ck-minibobStage {
    max-width: var(--prague-max);
    margin-inline: auto;
    padding-inline: var(--prague-gutter);
    margin-bottom: var(--space-6);
    text-align: center;
  }

  .ck-minibobStage__actions {
    display: flex;
    justify-content: center;
    margin-top: var(--space-4);
  }

  .ck-minibob__embed {
    width: 100%;
  }

  @media (max-width: 900px) {
    .ck-minibobStage {
      margin-bottom: var(--space-5);
    }
  }
</style>
