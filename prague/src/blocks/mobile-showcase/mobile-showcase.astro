---
import InstanceEmbed from '../../components/InstanceEmbed.astro';

type Props = {
  items?: {
    accountInstanceRef: {
      accountPublicId: string;
      instanceId: string;
      locale?: string;
    };
  }[];
  options?: any;
  widgetType?: string;
};

const { items = [], widgetType } = Astro.props;
if (!items.length) {
  throw new Error('[prague] mobile-showcase requires at least one accountInstanceRef item');
}
---

<div class="mobile-showcase" data-block="mobile-showcase">
  <div class="showcase-scroller">
    {items.map((item, index) => (
      <div class="mobile-frame">
        <InstanceEmbed
          accountPublicId={item.accountInstanceRef.accountPublicId}
          instanceId={item.accountInstanceRef.instanceId}
          locale={item.accountInstanceRef.locale}
          title={`${widgetType || 'Widget'} preview ${index + 1}`}
          widgetType={widgetType}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .mobile-showcase {
    display: flex;
    gap: var(--pkg-spacing-4);
    overflow-x: auto;
    padding: var(--pkg-spacing-4);
  }
</style>
