---
import InstanceEmbed from '../../components/InstanceEmbed.astro';

type Props = {
  items?: {
    accountInstanceRef: {
      accountPublicId: string;
      instanceId: string;
      locale?: string;
    };
  }[];
  options?: any;
  widgetType?: string;
};

const { items = [], widgetType } = Astro.props;
if (!items.length) {
  throw new Error('[prague] embed-carousel requires at least one accountInstanceRef item');
}
---

<div class="embed-carousel" data-block="embed-carousel">
  <div class="carousel-track">
    {items.map((item, index) => (
      <div class="carousel-item">
        <InstanceEmbed
          accountPublicId={item.accountInstanceRef.accountPublicId}
          instanceId={item.accountInstanceRef.instanceId}
          locale={item.accountInstanceRef.locale}
          title={`${widgetType || 'Widget'} preview ${index + 1}`}
          widgetType={widgetType}
        />
      </div>
    ))}
  </div>
</div>

<style>
  .embed-carousel {
    display: block;
    overflow-x: auto;
    padding: var(--pkg-spacing-4);
  }
</style>
