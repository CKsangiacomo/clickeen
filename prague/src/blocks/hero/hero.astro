---
import {
  actionGroupFromLegacy,
  actionGroupToPrimitives,
  assertPrimitives,
  type ActionGroup,
} from '../../composition/index';
import PrimitiveRenderer from '../../composition/renderers/astro/PrimitiveRenderer.astro';
import InstanceEmbed from '../../components/InstanceEmbed.astro';
import Carousel from '../../components/Carousel.astro';

type CarouselItem = {
  accountInstanceRef: {
    accountPublicId: string;
    instanceId: string;
    locale?: string;
  };
};

type Props = {
  headline: string;
  subheadline?: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  actionGroup?: ActionGroup;
  widgetType?: string;
  accountInstanceRef?: {
    instanceId: string;
    accountPublicId: string;
    locale?: string;
  };
  items?: CarouselItem[];
};

const { headline, subheadline, primaryCta, secondaryCta, actionGroup, widgetType, accountInstanceRef, items } = Astro.props;
const hasWidgetVisual = Boolean((items && items.length > 0) || accountInstanceRef);

const resolvedActionGroup =
  actionGroup ??
  actionGroupFromLegacy(primaryCta, secondaryCta, {
    layout: 'row',
    className: 'ck-row',
    primaryClassName: 'ck-btn--lg label-l',
    secondaryClassName: 'ck-btn--secondaryCta ck-btn--lg label-l',
  });

const headerPrimitives = assertPrimitives(
  [
    {
      type: 'heading',
      level: 1,
      content: headline,
      className: 'display-2 ck-hero__title ck-m0',
    },
    ...(subheadline
      ? [
          {
            type: 'text',
            variant: 'body',
            content: subheadline,
            className: 'body-website ck-hero__subheadline ck-m0 ck-text-secondary',
          },
        ]
      : []),
  ],
  'hero.header',
);
---

<section class="ck-canvas ck-heroCanvas">
  <div class="ck-inline">
    <div class="ck-hero__subnav">
      <slot name="subnav" />
    </div>
    <div class={`ck-split ck-split--center ck-split--hero${hasWidgetVisual ? '' : ' ck-split--copyOnly'}`}>
      <div class="ck-split__a">
        <div class="ck-hero__content ck-stack ck-gap-loose">
          <div class="ck-hero__copy ck-stack ck-gap-tight">
            <PrimitiveRenderer primitives={headerPrimitives} />
          </div>
          {resolvedActionGroup ? (
            <div class="ck-hero__cta">
              <PrimitiveRenderer primitives={[actionGroupToPrimitives(resolvedActionGroup)]} />
            </div>
          ) : null}
        </div>
      </div>
      {hasWidgetVisual ? (
        <div class="ck-split__b" aria-hidden="true">
          {items && items.length > 0 ? (
            <Carousel items={items} widgetType={widgetType} id={`hero-carousel-${headline.replace(/\s+/g, '-').toLowerCase()}`} />
          ) : accountInstanceRef ? (
            <InstanceEmbed
              instanceId={accountInstanceRef.instanceId}
              accountPublicId={accountInstanceRef.accountPublicId}
              locale={accountInstanceRef.locale}
              title={`${widgetType || 'Widget'} preview`}
              loading="eager"
              widgetType={widgetType}
            />
          ) : null}
        </div>
      ) : null}
    </div>
  </div>
</section>

<style>
  .ck-heroCanvas {
    /* Tokenized “gray 5.5” in our ladder corresponds to gray-5 step5. */
      background: var(--color-system-gray-5-step4);
    /* When the global nav is in overlay mode, keep hero content readable while
       allowing the background to extend under the nav. */
    padding-top: var(--ck-siteNav-h, 0px);
  }

  .ck-hero__subnav {
    margin-bottom: var(--space-7);
  }
  .ck-hero__subnav:empty { display: none; }

  .ck-hero__title { margin: 0 !important; }
  .ck-hero__subheadline { margin: 0 !important; }
</style>
