---
import Base from '../../../../../../layouts/Base.astro';
import Nav from '../../../../../../blocks/site/nav/Nav.astro';
import Footer from '../../../../../../blocks/site/footer.astro';
import WidgetBlocks from '../../../../../../components/WidgetBlocks.astro';
import { loadRequiredWidgetPageJsonForLocale } from '../../../../../../lib/markdown';
import { getPragueMarket, toMarketHreflang } from '../../../../../../lib/markets';
import { resolvePragueWidgetLabel } from '../../../../../../lib/widgetLabels';

const { market, locale, widget, page } = Astro.params;
export const prerender = false;

type WidgetSubpage = 'overview' | 'examples' | 'features' | 'pricing';
const activeSubpage: WidgetSubpage =
  page === 'overview' || page === 'examples' || page === 'features' || page === 'pricing'
    ? (page as WidgetSubpage)
    : 'overview';

const url = Astro.url;
if (!url.pathname.endsWith('/')) {
  return Astro.redirect(`${url.pathname}/${url.search}`, 301);
}

const marketKey = String(market || '').trim().toLowerCase();
const localeKey = String(locale || '').trim().toLowerCase();
const widgetKey = String(widget || '').trim();
const pageKey = String(page || '').trim().toLowerCase();

if (pageKey === 'overview') {
  return Astro.redirect(`/${marketKey}/${localeKey}/widgets/${encodeURIComponent(widgetKey)}/${url.search}`, 301);
}

const isValidSubpage = pageKey === 'examples' || pageKey === 'features' || pageKey === 'pricing';

const marketConfig = getPragueMarket(marketKey);
if (!marketConfig) {
  return Astro.redirect(`/${url.search}`, 302);
}
if (marketConfig && !marketConfig.locales.includes(localeKey)) {
  return Astro.redirect(
    `/${marketConfig.key}/${marketConfig.defaultLocale}/widgets/${encodeURIComponent(widgetKey)}/${encodeURIComponent(activeSubpage)}/${url.search}`,
    302,
  );
}
if (!isValidSubpage) {
  Astro.response.status = 404;
}

const widgetSegment = encodeURIComponent(widgetKey);
const canonicalPath =
  marketConfig && isValidSubpage ? `/${marketConfig.key}/${localeKey}/widgets/${widgetSegment}/${encodeURIComponent(activeSubpage)}/` : null;
const alternates =
  marketConfig && isValidSubpage
    ? [
        ...marketConfig.locales.map((l) => ({
          hreflang: toMarketHreflang({ locale: l, country: marketConfig.country }),
          href: `/${marketConfig.key}/${l}/widgets/${widgetSegment}/${encodeURIComponent(activeSubpage)}/`,
        })),
        {
          hreflang: 'x-default',
          href: `/${marketConfig.key}/${marketConfig.defaultLocale}/widgets/${widgetSegment}/${encodeURIComponent(activeSubpage)}/`,
        },
      ]
    : null;

let blocks: any[] = [];
let hasHero = false;
let pageTitle = '';
let pageDescription = '';
let createFreeLabel = '';

if (!marketConfig) {
  Astro.response.status = 404;
  pageTitle = 'Not found';
  pageDescription = 'Unknown market.';
} else if (!isValidSubpage) {
  Astro.response.status = 404;
  pageTitle = 'Not found';
  pageDescription = 'Unknown widget subpage.';
} else {
  const pageJson = await loadRequiredWidgetPageJsonForLocale({
    widget: widgetKey,
    page: pageKey,
    locale: localeKey,
  });
  blocks = Array.isArray((pageJson as any).blocks) ? (pageJson as any).blocks : [];
  hasHero = blocks.some((b: any) => b && b.type === 'hero');
  const pageMetaBlock = blocks.find((b: any) => b && b.type === 'page-meta');
  const pageMeta = pageMetaBlock && typeof pageMetaBlock === 'object' ? (pageMetaBlock as any).copy : null;
  pageTitle = pageMeta && typeof pageMeta === 'object' ? String((pageMeta as any).title ?? '') : '';
  pageDescription = pageMeta && typeof pageMeta === 'object' ? String((pageMeta as any).description ?? '') : '';
  if (!pageTitle || !pageDescription) {
    throw new Error(
      `[prague] Invalid tokyo/prague/pages/${widgetKey}/${page}.json (page-meta.copy.title/description required)`,
    );
  }
  const widgetDisplayName = resolvePragueWidgetLabel(widgetKey);
  createFreeLabel = `Create a free ${widgetDisplayName} widget`;
}
---

<Base title={pageTitle || 'Not found'} description={pageDescription || undefined} locale={localeKey || 'en'} canonicalPath={canonicalPath ?? undefined} alternates={alternates ?? undefined}>
  {!marketConfig || !isValidSubpage ? (
    <main class="ck-canvas">
      <div class="ck-inline">
        <div class="ck-stack">
          <h1 class="heading-3 ck-m0">{marketConfig && isValidSubpage ? pageTitle : 'Not found'}</h1>
          <p class="body-1 ck-text-muted ck-m0">
            {!marketConfig ? 'Unknown market.' : 'Unknown widget subpage.'}
          </p>
        </div>
      </div>
    </main>
  ) : (
    <main>
      <Nav
        title="Clickeen"
        market={marketConfig.key}
        locale={localeKey}
        homeHref={`/${marketConfig.key}/${localeKey}/`}
        overlay={hasHero}
        cta={{ label: createFreeLabel, href: `/${marketConfig.key}/${localeKey}/create`, variant: 'primary' }}
      />

      <WidgetBlocks
        blocks={blocks}
        widget={widgetKey}
        market={marketConfig.key}
        locale={localeKey}
        activeSubpage={activeSubpage}
        primaryCta={{ label: createFreeLabel, href: `/${marketConfig.key}/${localeKey}/create` }}
      />

      <Footer market={marketConfig.key} locale={localeKey} />
    </main>
  )}
</Base>
