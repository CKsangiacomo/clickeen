---
import Cta from '../blocks/cta/cta.astro';
import BigBang from '../blocks/big-bang/big-bang.astro';
import ControlMoat from '../blocks/control-moat/control-moat.astro';
import GlobalMoat from '../blocks/global-moat/global-moat.astro';
import Hero from '../blocks/hero/hero.astro';
import Minibob from '../blocks/minibob/minibob.astro';
import PlatformStrip from '../blocks/platform-strip/platform-strip.astro';
import Split from '../blocks/split/split.astro';
import SplitCarousel from '../blocks/split-carousel/SplitCarousel.astro';
import Steps from '../blocks/steps/steps.astro';
import SubpageCards from '../blocks/subpage-cards/subpage-cards.astro';
import EmbedCarousel from '../blocks/embed-carousel/embed-carousel.astro';
import FeatureExplorer from '../blocks/feature-explorer/feature-explorer.astro';
import MobileShowcase from '../blocks/mobile-showcase/mobile-showcase.astro';
import WidgetSubnav from '../blocks/site/nav/WidgetSubnav.astro';
import { pragueT } from '../lib/i18n';
import { localeLabel } from '../lib/localeLabels';

type Block = {
  id: string;
  type: string;
  copy: Record<string, any>;
  visual?: { image?: string };
  links?: any;
  align?: string;
  accountInstanceRef?: {
    accountPublicId?: string;
    instanceId?: string;
    locale?: string;
  };
};

type AccountInstanceRef = {
  accountPublicId: string;
  instanceId: string;
  locale?: string;
};

type FeatureItem = {
  title: string;
  body: string;
  iconEnabled?: boolean;
  iconName?: string;
  backgroundEnabled?: boolean;
  backgroundPath?: string;
  imageEnabled?: boolean;
  imagePath?: string;
  imageAlt?: string;
  imageLayout?: 'inset' | 'bleed';
  imageFit?: 'cover' | 'contain';
  imagePositionY?: 'top' | 'center' | 'bottom';
};

type Props = {
  blocks: Block[];
  widget: string;
  market: string;
  locale: string;
  activeSubpage?: 'overview' | 'examples' | 'features' | 'pricing';
  primaryCta: { label: string; href: string };
};

const { blocks, widget, market, locale, activeSubpage = 'overview', primaryCta } = Astro.props;
const routeLocale = String(locale || '').trim();
if (!routeLocale) {
  throw new Error(`[prague] ${widget}/${activeSubpage}: route locale is required`);
}
const routeLocaleHeroSubhead = await pragueT(locale, 'prague.hero.overview.subheadOne');
const heroPrimaryCta = primaryCta;

function renderOverviewHeroSubheadline(args: { selectedLocale: string }): string | null {
  const selectedLocale = String(args.selectedLocale || '').trim();
  if (!selectedLocale) return null;
  return routeLocaleHeroSubhead.replace('{lang1}', localeLabel(selectedLocale, locale));
}

function requireInstanceId(context: string, value?: string | null): string {
  const instanceId = String(value || '').trim();
  if (!instanceId) {
    throw new Error(`[prague] ${widget}/${activeSubpage}: ${context} requires explicit accountInstanceRef.instanceId`);
  }
  return instanceId;
}

function requireAccountPublicId(context: string, value?: string | null): string {
  const accountPublicId = String(value || '').trim();
  if (!accountPublicId) {
    throw new Error(`[prague] ${widget}/${activeSubpage}: ${context} requires explicit accountInstanceRef.accountPublicId`);
  }
  return accountPublicId;
}

function resolveAccountInstanceRef(context: string, ref?: Block['accountInstanceRef']): AccountInstanceRef | undefined {
  if (!ref) return undefined;
  const resolved: AccountInstanceRef = {
    accountPublicId: requireAccountPublicId(context, ref.accountPublicId),
    instanceId: requireInstanceId(context, ref.instanceId),
  };
  const authoredLocale = String(ref.locale || '').trim();
  return authoredLocale ? { ...resolved, locale: authoredLocale } : resolved;
}
---

{blocks.map((block) => {
  if (!block || !block.type) return null;
  let rendered: any = null;
  switch (block.type) {
    case 'big-bang': {
      const copy = block.copy ?? {};
      rendered = (
        <BigBang
          headline={String(copy.headline ?? '')}
          body={String(copy.body ?? '')}
          primaryCta={heroPrimaryCta}
          secondaryCta={undefined}
        />
      );
      break;
    }
    case 'hero': {
      const copy = block.copy ?? {};
      const blockAccountInstanceRef = resolveAccountInstanceRef('hero', block.accountInstanceRef);
      const explicitHeroItems = Array.isArray((block as any).items) ? ((block as any).items as any[]) : [];
      const mappedHeroItems = explicitHeroItems.map((item: any) => {
        return {
          ...item,
          accountInstanceRef: resolveAccountInstanceRef('hero item', item.accountInstanceRef),
        };
      });
      const dynamicOverviewSubheadline =
        activeSubpage === 'overview' && mappedHeroItems.length === 0
          ? renderOverviewHeroSubheadline({
              selectedLocale: routeLocale,
            })
          : null;
      rendered = (
        <Hero
          headline={String(copy.headline ?? '')}
          subheadline={dynamicOverviewSubheadline || String(copy.subheadline ?? '')}
          primaryCta={heroPrimaryCta}
          secondaryCta={undefined}
          widgetType={widget}
          accountInstanceRef={blockAccountInstanceRef}
          items={mappedHeroItems}
        >
          <WidgetSubnav slot="subnav" market={market} locale={locale} widget={widget} active={activeSubpage} variant="inline" />
        </Hero>
      );
      break;
    }
    case 'split': {
      const copy = block.copy ?? {};
      const blockAccountInstanceRef = resolveAccountInstanceRef('split', block.accountInstanceRef);
      const layout = typeof (block as any).layout === 'string' ? (block as any).layout : '';
      rendered = (
        <Split
          headline={String(copy.headline ?? '')}
          subheadline={String(copy.subheadline ?? '')}
          primaryCta={heroPrimaryCta}
          secondaryCta={undefined}
          widgetType={widget}
          layout={layout}
          accountInstanceRef={blockAccountInstanceRef}
        />
      );
      break;
    }
    case 'split-carousel': {
      const copy = block.copy ?? {};
      const layout = typeof (block as any).layout === 'string' ? (block as any).layout : '';
      rendered = (
        <SplitCarousel
          headline={String(copy.headline ?? '')}
          subheadline={String(copy.subheadline ?? '')}
          primaryCta={heroPrimaryCta}
          secondaryCta={undefined}
          widgetType={widget}
          layout={layout}
          items={((block as any).items ?? []).map((item: any) => {
            return {
              ...item,
              accountInstanceRef: resolveAccountInstanceRef('split-carousel item', item.accountInstanceRef),
            };
          })}
        />
      );
      break;
    }
    case 'steps': {
      const copy = block.copy ?? {};
      rendered = (
        <Steps
          widget={widget}
          title={copy.title as string}
          subhead={copy.subhead as string}
          steps={(copy.items ?? []) as FeatureItem[]}
          visual={block.visual}
          ctaHref={heroPrimaryCta.href}
        />
      );
      break;
    }
    case 'subpage-cards': {
      const copy = block.copy ?? {};
      const links = Array.isArray((block as any).links) ? ((block as any).links as any[]) : [];
      rendered = (
        <SubpageCards
          widget={widget}
          market={market}
          locale={locale}
          title={String(copy.title ?? '')}
          subhead={typeof copy.subhead === 'string' ? copy.subhead : undefined}
          items={(copy.items ?? []) as { title: string; body: string }[]}
          links={links as { page: 'examples' | 'features' | 'pricing'; iconName?: string }[]}
        />
      );
      break;
    }
    case 'control-moat': {
      const copy = block.copy ?? {};
      rendered = (
        <ControlMoat
          widget={widget}
          title={copy.title as string}
          subhead={copy.subhead as string}
          items={(copy.items ?? []) as FeatureItem[]}
          visual={block.visual}
          ctaHref={heroPrimaryCta.href}
        />
      );
      break;
    }
    case 'global-moat': {
      const copy = block.copy ?? {};
      rendered = (
        <GlobalMoat
          widget={widget}
          title={copy.title as string}
          subhead={copy.subhead as string}
          items={(copy.items ?? []) as FeatureItem[]}
          visual={block.visual}
          ctaHref={heroPrimaryCta.href}
        />
      );
      break;
    }
    case 'platform-strip': {
      const copy = block.copy ?? {};
      rendered = (
        <PlatformStrip
          widget={widget}
          title={copy.title as string}
          subhead={copy.subhead as string}
          items={(copy.items ?? []) as FeatureItem[]}
          visual={block.visual}
          ctaHref={heroPrimaryCta.href}
        />
      );
      break;
    }
    case 'cta-bottom-block': {
      const copy = block.copy ?? {};
      rendered = (
        <Cta
          headline={String(copy.headline ?? '')}
          subheadline={String(copy.subheadline ?? '')}
          primaryCta={heroPrimaryCta}
        />
      );
      break;
    }
    case 'minibob': {
      const copy = block.copy ?? {};
      const minibobAccountPublicId = requireAccountPublicId('minibob', block.accountInstanceRef?.accountPublicId);
      const minibobInstanceId = requireInstanceId('minibob', block.accountInstanceRef?.instanceId);
      const minibobLocale = String(block.accountInstanceRef?.locale || '').trim() || undefined;
      rendered = (
        <>
          <Minibob
            widget={widget}
            routeLocale={routeLocale}
            embedLocale={minibobLocale}
            page={activeSubpage}
            heading={String(copy.heading ?? '')}
            subhead={String(copy.subhead ?? '')}
            accountPublicId={minibobAccountPublicId}
            instanceId={minibobInstanceId}
          />
        </>
      );
      break;
    }
    case 'embed-carousel': {
      const copy = block.copy ?? {};
      rendered = (
        <EmbedCarousel
          items={(block as any).items ?? []}
          options={(block as any).options ?? {}}
          widgetType={widget}
        />
      );
      break;
    }
    case 'mobile-showcase': {
      const copy = block.copy ?? {};
      rendered = (
        <MobileShowcase
          items={(block as any).items ?? []}
          options={(block as any).options ?? {}}
          widgetType={widget}
        />
      );
      break;
    }
    case 'feature-explorer': {
      const copy = block.copy ?? {};
      rendered = (
        <FeatureExplorer
          categories={(block as any).categories ?? []}
          options={(block as any).options ?? {}}
        />
      );
      break;
    }
    case 'navmeta':
    case 'page-meta':
      return null;
    default:
      throw new Error(`[prague] No renderer for block type \"${block.type}\"`);
  }

  return rendered;
})}
