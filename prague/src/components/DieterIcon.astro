---
type Props = {
  name: string;
  size?: number;
};

const { name, size = 40 } = Astro.props;
const TOKYO_URL = import.meta.env.PUBLIC_TOKYO_URL;

if (!TOKYO_URL) {
  throw new Error('[DieterIcon] PUBLIC_TOKYO_URL is required');
}

const iconUrl = `${TOKYO_URL.replace(/\/$/, '')}/dieter/icons/svg/${name}.svg`;
const maskUrl = `url(${JSON.stringify(iconUrl)})`;
---

<span
  data-dieter-icon={name}
  aria-hidden="true"
  role="presentation"
  style={`display: inline-block; width: ${size}px; height: ${size}px; background-color: currentColor; -webkit-mask: ${maskUrl} center / contain no-repeat; mask: ${maskUrl} center / contain no-repeat;`}
/>
