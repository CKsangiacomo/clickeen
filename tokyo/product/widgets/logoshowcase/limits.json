{
  "v": 1,
  "limits": [
    {
      "kind": "flag",
      "key": "branding.remove",
      "path": "behavior.showBacklink",
      "mode": "boolean",
      "deny": false,
      "sanitizeTo": true,
      "enforce": {
        "load": "sanitize",
        "ops": "reject",
        "publish": "reject"
      }
    },
    {
      "kind": "flag",
      "key": "widget.socialShare.enabled",
      "path": "behavior.socialShare.enabled",
      "mode": "boolean",
      "deny": true,
      "sanitizeTo": false,
      "enforce": {
        "load": "sanitize",
        "ops": "reject",
        "publish": "reject"
      }
    },
    {
      "kind": "limit",
      "key": "items.group.small.max",
      "path": "strips[]",
      "metric": "count"
    },
    {
      "kind": "limit",
      "key": "items.group.medium.max",
      "path": "strips[].logos[]",
      "metric": "count"
    },
    {
      "kind": "limit",
      "key": "items.group.large.max",
      "path": "strips[].logos[]",
      "metric": "count-total"
    }
  ]
}
