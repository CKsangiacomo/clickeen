{
  "v": 1,
  "widgetname": "logoshowcase",
  "itemKey": "logoshowcase.item",
  "normalization": {
    "idRules": [
      {
        "arrayPath": "logoshowcase.strips",
        "idKey": "id"
      },
      {
        "arrayPath": "logoshowcase.strips[].logos",
        "idKey": "id"
      }
    ]
  },
  "defaults": {
    "uiLabels": {
      "core": {
        "singular": "Logo tile",
        "plural": "Logo tiles",
        "sizeCluster": "Logo showcase size"
      }
    },
    "logoshowcase": {
      "type": "grid",
      "strips": [
        {
          "id": "s1",
          "logos": [
            {
              "id": "l1",
              "alt": "",
              "href": "",
              "name": "",
              "title": "",
              "caption": "",
              "logoFill": "transparent",
              "nofollow": false,
              "targetBlank": false
            }
          ]
        }
      ],
      "spacing": {
        "gap": 20,
        "rowGap": 16,
        "stripGap": 16,
        "mobileGap": 16,
        "logoHeight": 40,
        "mobileStripGap": 12
      },
      "behavior": {
        "randomOrder": false
      },
      "appearance": {
        "cardwrapper": {
          "border": {
            "color": "color-mix(in oklab, var(--color-system-black), transparent 88%)",
            "width": 1,
            "enabled": false
          },
          "radius": "4xl",
          "shadow": {
            "x": 0,
            "y": 8,
            "blur": 24,
            "alpha": 18,
            "color": "#000000",
            "inset": false,
            "spread": 0,
            "enabled": false
          },
          "radiusBL": "4xl",
          "radiusBR": "4xl",
          "radiusTL": "4xl",
          "radiusTR": "4xl",
          "radiusLinked": true
        },
        "logoLook": "original",
        "logoOpacity": 0.9,
        "itemBackground": {
          "type": "none"
        }
      },
      "typeConfig": {
        "carousel": {
          "mode": "paged",
          "step": "page",
          "speed": 30,
          "autoplay": false,
          "direction": "left",
          "allowSwipe": true,
          "showArrows": true,
          "pauseOnHover": true,
          "transitionMs": 350,
          "autoSlideDelayMs": 2500
        }
      }
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "nodes": [
              {
                "kind": "field",
                "type": "segmented",
                "groupId": "content-type",
                "path": "logoshowcase.type",
                "label": "Type",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "value": "{{logoshowcase.type}}",
                  "options": [
                    {
                      "label": "Grid",
                      "value": "grid",
                      "icon": "circle.grid.2x2"
                    },
                    {
                      "label": "Carousel",
                      "value": "carousel",
                      "icon": "ellipsis"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "object-manager",
                "groupId": "content-logos",
                "path": "logoshowcase.strips",
                "template": [
                  {
                    "kind": "field",
                    "type": "repeater",
                    "path": "logoshowcase.strips.__STRIP__.logos",
                    "label": "Logos",
                    "template": [
                      {
                        "kind": "field",
                        "type": "dropdown-upload",
                        "path": "logoshowcase.strips.__STRIP__.logos.__INDEX__.logoFill",
                        "label": "Logo",
                        "template": [
                          {
                            "kind": "field",
                            "type": "textfield",
                            "path": "logoshowcase.strips.__STRIP__.logos.__INDEX__.name",
                            "label": "Name",
                            "attrs": {
                              "size": "sm",
                              "placeholder": "Logo name"
                            }
                          },
                          {
                            "kind": "field",
                            "type": "textfield",
                            "path": "logoshowcase.strips.__STRIP__.logos.__INDEX__.caption",
                            "label": "Caption",
                            "attrs": {
                              "size": "sm",
                              "placeholder": "Optional caption"
                            }
                          }
                        ],
                        "attrs": {
                          "size": "md",
                          "meta-path": "logoshowcase.strips.__STRIP__.logos.__INDEX__.asset",
                          "placeholder": "Upload logo",
                          "accept": "image/*,.svg"
                        }
                      }
                    ],
                    "attrs": {
                      "size": "md",
                      "add-label": "Add logo",
                      "remove-label": "Remove logo {index}",
                      "move-label": "Move logo {index}",
                      "reorder-label": "Manage logos",
                      "reorder-title": "Manage logos",
                      "add-open": "bulk-edit",
                      "min": "1",
                      "default-item": {
                        "name": "New logo",
                        "logoFill": "transparent",
                        "href": "",
                        "targetBlank": false,
                        "nofollow": false,
                        "alt": "",
                        "title": "",
                        "caption": ""
                      }
                    }
                  }
                ],
                "attrs": {
                  "group-label": "",
                  "class": "diet-object-manager",
                  "add-label": "Add strip",
                  "reorder-label": "Manage strips",
                  "reorder-title": "Manage strips",
                  "label-path": "logos.0.name",
                  "index-token": "__STRIP__",
                  "min": "1",
                  "default-item": {
                    "logos": [
                      {
                        "name": "New logo",
                        "logoFill": "transparent",
                        "href": "",
                        "targetBlank": false,
                        "nofollow": false,
                        "alt": "",
                        "title": "",
                        "caption": ""
                      }
                    ]
                  }
                }
              },
              {
                "kind": "field",
                "type": "bulk-edit",
                "groupId": "content-logos",
                "path": "logoshowcase.strips",
                "label": "Logo details...",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "row-path": "logos",
                  "title": "Logo details",
                  "columns": [
                    {
                      "label": "Logo",
                      "path": "logoFill",
                      "metaPath": "asset",
                      "autoNamePath": "name",
                      "control": "upload",
                      "placeholder": "Upload logo",
                      "accept": "image/*,.svg"
                    },
                    {
                      "label": "Name",
                      "path": "name",
                      "control": "text"
                    },
                    {
                      "label": "Caption",
                      "path": "caption",
                      "control": "text"
                    },
                    {
                      "label": "URL",
                      "path": "href",
                      "control": "text",
                      "placeholder": "https://example.com"
                    },
                    {
                      "label": "Open in new tab",
                      "path": "targetBlank",
                      "control": "checkbox"
                    },
                    {
                      "label": "Nofollow",
                      "path": "nofollow",
                      "control": "checkbox"
                    },
                    {
                      "label": "Alt text",
                      "path": "alt",
                      "control": "text"
                    },
                    {
                      "label": "Title (tooltip)",
                      "path": "title",
                      "control": "text"
                    }
                  ]
                }
              }
            ]
          },
          {
            "nodes": [
              {
                "kind": "field",
                "type": "segmented",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.mode",
                "label": "Mode",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Paged",
                      "value": "paged"
                    },
                    {
                      "label": "Continuous",
                      "value": "continuous"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "segmented",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.step",
                "label": "Step",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "paged"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "By logo",
                      "value": "logo"
                    },
                    {
                      "label": "By page",
                      "value": "page"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.showArrows",
                "label": "Show arrows",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "paged"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.allowSwipe",
                "label": "Allow swipe/drag",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "paged"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.autoplay",
                "label": "Autoplay",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "paged"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.autoSlideDelayMs",
                "label": "Autoplay delay (ms)",
                "showIf": {
                  "all": [
                    {
                      "path": "logoshowcase.typeConfig.carousel.mode",
                      "op": "equals",
                      "value": "paged"
                    },
                    {
                      "path": "logoshowcase.typeConfig.carousel.autoplay",
                      "op": "isTrue"
                    }
                  ]
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.transitionMs",
                "label": "Transition (ms)",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "paged"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.speed",
                "label": "Speed (px/sec)",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "continuous"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "dropdown-actions",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.direction",
                "label": "Direction",
                "showIf": {
                  "path": "logoshowcase.typeConfig.carousel.mode",
                  "op": "equals",
                  "value": "continuous"
                },
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "value": "{{logoshowcase.typeConfig.carousel.direction}}",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Right",
                      "value": "right"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "carousel-settings",
                "path": "logoshowcase.typeConfig.carousel.pauseOnHover",
                "label": "Pause on hover",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              }
            ],
            "showIf": {
              "path": "logoshowcase.type",
              "op": "equals",
              "value": "carousel"
            }
          }
        ]
