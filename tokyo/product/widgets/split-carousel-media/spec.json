          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "core-size"
          },
          {
            "label": "Media fit",
            "nodes": [
              {
                "kind": "field",
                "type": "dropdown-actions",
                "groupId": "layout-media-fit",
                "path": "splitCarouselMedia.media.fit",
                "label": "Fit",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Cover",
                      "value": "cover"
                    },
                    {
                      "label": "Contain",
                      "value": "contain"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "dropdown-actions",
                "groupId": "layout-media-fit",
                "path": "splitCarouselMedia.media.position",
                "label": "Position",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Center",
                      "value": "center"
                    },
                    {
                      "label": "Top",
                      "value": "top"
                    },
                    {
                      "label": "Bottom",
                      "value": "bottom"
                    },
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Right",
                      "value": "right"
                    }
                  ]
                }
              }
            ]
          },
          {
            "label": "Carousel",
            "nodes": [
              {
                "kind": "field",
                "type": "dropdown-actions",
                "groupId": "layout-carousel",
                "path": "splitCarouselMedia.carousel.transition",
                "label": "Transition",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Slide",
                      "value": "slide"
                    },
                    {
                      "label": "Fade",
                      "value": "fade"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "layout-carousel",
                "path": "splitCarouselMedia.carousel.autoplay",
                "label": "Autoplay",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "groupId": "layout-carousel",
                "path": "splitCarouselMedia.carousel.intervalMs",
                "label": "Interval (ms)",
                "attrs": {
                  "group-label": "",
                  "min": "2000",
                  "max": "12000"
                },
                "showIf": {
                  "path": "splitCarouselMedia.carousel.autoplay",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "layout-carousel",
                "path": "splitCarouselMedia.carousel.loop",
                "label": "Loop",
                "attrs": {
                  "group-label": "",
                  "size": "md"
