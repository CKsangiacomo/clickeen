{
  "widgetname": "split-carousel-media",
  "displayName": "Split Carousel Media",
  "description": "",
  "itemKey": "split-carousel-media.item",
  "defaults": {
    "uiLabels": {
      "core": {
        "singular": "Carousel visual",
        "plural": "Carousel visuals",
        "sizeCluster": "Carousel visual size"
      }
    },
    "splitCarouselMedia": {
      "items": [
        {
          "id": "visual-1",
          "media": {
            "type": "none"
          },
          "alt": ""
        },
        {
          "id": "visual-2",
          "media": {
            "type": "none"
          },
          "alt": ""
        }
      ],
      "media": {
        "fit": "cover",
        "position": "center"
      },
      "carousel": {
        "transition": "slide",
        "autoplay": false,
        "intervalMs": 5000,
        "loop": true,
        "showArrows": true,
        "showDots": true
      },
      "appearance": {
        "cardwrapper": {
          "radiusLinked": true,
          "radius": "4xl",
          "radiusTL": "4xl",
          "radiusTR": "4xl",
          "radiusBR": "4xl",
          "radiusBL": "4xl",
          "border": {
            "enabled": false,
            "width": 1,
            "color": "var(--color-system-gray-5)"
          },
          "shadow": {
            "enabled": true,
            "x": 0,
            "y": 24,
            "blur": 80,
            "spread": 0,
            "alpha": 12,
            "color": "#000000",
            "inset": false
          }
        }
      }
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "label": "Carousel visuals",
            "nodes": [
              {
                "kind": "field",
                "type": "repeater",
                "groupId": "content-carousel-visuals",
                "path": "splitCarouselMedia.items",
                "label": "Visuals",
                "template": [
                  {
                    "kind": "field",
                    "type": "dropdown-fill",
                    "path": "splitCarouselMedia.items.__INDEX__.media",
                    "label": "Media",
                    "attrs": {
                      "size": "md",
                      "fill-modes": "image,video",
                      "allow-image": "true"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "splitCarouselMedia.items.__INDEX__.alt",
                    "label": "Alt text"
                  }
                ],
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "add-label": "Add visual",
                  "remove-label": "Remove visual {index}",
                  "move-label": "Move visual {index}",
                  "reorder-label": "Reorder visuals",
                  "reorder-title": "Reorder visuals",
                  "min": "2",
                  "max": "6",
                  "default-item": {
                    "id": "",
                    "media": {
                      "type": "none"
                    },
                    "alt": ""
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
