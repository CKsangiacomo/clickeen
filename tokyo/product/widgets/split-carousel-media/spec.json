              {
                "kind": "field",
                "type": "toggle",
                "groupId": "layout-carousel",
                "path": "splitCarouselMedia.carousel.showDots",
                "label": "Show dots",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
