{
  "widgetname": "big-bang",
  "displayName": "Big Bang",
  "description": "",
  "itemKey": "bigBang.item",
  "defaults": {
    "uiLabels": {
      "core": {
        "singular": "Statement",
        "plural": "Statements",
        "sizeCluster": "Statement size"
      }
    },
    "typography": {
      "roles": {
        "bigBang": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "800",
          "fontStyle": "normal",
          "sizeCustom": 84,
          "sizePreset": "custom",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 0.94,
          "lineHeightPreset": "custom"
        }
      },
      "roleScales": {
        "bigBang": {
          "l": "104px",
          "m": "84px",
          "s": "64px",
          "xl": "128px",
          "xs": "48px"
        }
      }
    },
    "bigBang": {
      "statement": "Make the important message impossible to miss.",
      "showSupportingCopy": true,
      "supportingCopy": "Use a Big Bang section when a page needs one bold statement with enough rhythm to stop the scroll.",
      "alignment": "left",
      "textWidth": 880,
      "gap": 24
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "label": "Big Bang content",
            "nodes": [
              {
                "kind": "field",
                "type": "dropdown-edit",
                "path": "bigBang.statement",
                "label": "Statement",
                "attrs": {
                  "size": "lg",
                  "placeholder": "Add statement text",
                  "allow-links": "false",
                  "required": true
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "path": "bigBang.showSupportingCopy",
                "label": "Show supporting copy",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "dropdown-edit",
                "path": "bigBang.supportingCopy",
                "label": "Supporting copy",
                "attrs": {
                  "size": "md",
                  "placeholder": "Add supporting copy",
                  "allow-links": "false"
                },
                "showIf": {
                  "path": "bigBang.showSupportingCopy",
                  "op": "isTrue"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "core-size"
          },
          {
            "label": "Big Bang layout",
            "nodes": [
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "bigBang.alignment",
                "label": "Statement alignment",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Center",
                      "value": "center"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.textWidth",
                "label": "Statement width (px)",
                "attrs": {
                  "min": 480,
                  "max": 1280,
                  "step": 10
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.gap",
                "label": "Statement/copy gap (px)",
                "attrs": {
                  "min": 8,
                  "max": 80,
                  "step": 2
                }
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-appearance"
          },
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          }
        ]
      },
      {
        "id": "settings",
        "clusters": [
          {
            "kind": "shared",
            "id": "settings-behavior"
          }
        ]
      }
    ]
  }
}
