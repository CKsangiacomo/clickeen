                "kind": "field",
                "type": "choice-tiles",
                "path": "bigBang.alignment",
                "label": "Alignment",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Center",
                      "value": "center"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.textWidth",
                "label": "Text width",
                "attrs": {
                  "min": 480,
                  "max": 1280,
                  "step": 10
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.gap",
                "label": "Gap",
                "attrs": {
                  "min": 8,
                  "max": 80,
                  "step": 2
                }
