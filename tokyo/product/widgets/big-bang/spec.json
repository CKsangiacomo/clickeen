  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "label": "Big Bang content",
            "nodes": [
              {
                "kind": "field",
                "type": "textedit",
                "path": "bigBang.statement",
                "label": "Statement"
              },
              {
                "kind": "field",
                "type": "toggle",
                "path": "bigBang.showSupportingCopy",
                "label": "Show supporting copy",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "textedit",
                "path": "bigBang.supportingCopy",
                "label": "Supporting copy",
                "showIf": {
                  "path": "bigBang.showSupportingCopy",
                  "op": "isTrue"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "core-size"
          },
          {
            "label": "Big Bang layout",
            "nodes": [
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "bigBang.alignment",
                "label": "Alignment",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Center",
                      "value": "center"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.textWidth",
                "label": "Text width"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "bigBang.gap",
                "label": "Gap"
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-appearance"
          },
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          }
        ]
      },
      {
        "id": "settings",
        "clusters": [
          {
            "label": "Behavior",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "behavior.showBacklink",
                "label": "Show Made with Clickeen",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "path": "behavior.socialShare.enabled",
                "label": "Enable social share",
                "attrs": {
                  "size": "md"
                }
              }
            ]
          }
        ]
      }
