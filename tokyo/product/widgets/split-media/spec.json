          {
            "label": "Media fit",
            "nodes": [
              {
                "kind": "field",
                "type": "dropdown-actions",
                "groupId": "layout-media-fit",
                "path": "splitMedia.fit",
                "label": "Fit",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Cover",
                      "value": "cover"
