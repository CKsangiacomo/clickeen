                "kind": "field",
                "type": "dropdown-fill",
                "groupId": "content-visual",
                "path": "splitMedia.media",
                "label": "Media",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "fill-modes": "image,video",
                  "allow-image": "true"
                }
              },
              {
                "kind": "field",
                "type": "textfield",
                "groupId": "content-visual",
