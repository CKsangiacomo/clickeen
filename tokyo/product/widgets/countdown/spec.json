    "uiLabels": {
      "core": {
        "singular": "Timer tile",
        "plural": "Timer tiles",
        "sizeCluster": "Timer size"
      }
    },
    "typography": {
      "roles": {
        "label": {
          "color": {
            "type": "color",
            "color": "color-mix(in oklab, var(--color-system-black), transparent 45%)"
          },
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 14,
          "sizePreset": "custom"
        },
        "timer": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizeCustom": 48,
          "sizePreset": "custom"
        }
      },
      "roleScales": {
        "label": {
          "l": "16px",
          "m": "14px",
          "s": "12px",
          "xl": "18px",
          "xs": "11px"
        },
        "timer": {
          "l": "56px",
          "m": "48px",
          "s": "40px",
          "xl": "64px",
          "xs": "32px"
        }
      }
    },
    "countdown": {
      "timer": {
        "mode": "date",
        "repeat": "never",
        "timeUnit": "hours",
        "timezone": "UTC",
        "targetDate": "2030-01-01T00:00",
        "timeAmount": 1,
        "targetNumber": 1000,
        "countDuration": 5,
        "startingNumber": 0,
        "labels": {
          "days": "Days",
          "hours": "Hours",
          "minutes": "Minutes",
          "seconds": "Seconds"
        }
      },
      "actions": {
        "after": {
          "url": "",
          "text": "",
          "type": "hide"
        },
        "during": {
          "url": "#",
          "text": "Purchase now",
          "style": "primary",
          "newTab": true
        }
      },
      "appearance": {
        "timerStyle": "separated",
        "timeFormat": "auto",
        "showLabels": true,
        "separator": ":",
        "textColor": {
          "type": "color",
          "color": "var(--color-system-black)"
        },
        "itemBackground": {
          "type": "color",
          "color": "var(--color-system-gray-5)"
        },
        "cardwrapper": {
          "border": {
            "color": "var(--color-system-gray-5)",
            "width": 1,
            "enabled": false
          },
          "radius": "2xl",
