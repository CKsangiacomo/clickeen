{
  "v": 1,
  "widgetname": "split",
  "itemKey": "split.item",
  "normalization": {
    "coerceRules": [
      {
        "path": "behavior.showBacklink",
        "type": "boolean",
        "default": true
      },
      {
        "path": "behavior.socialShare.enabled",
        "type": "boolean",
        "default": false
      }
    ]
  },
  "defaults": {
    "headline": "",
    "subheadline": "",
    "primaryCta": {
      "enabled": false,
      "label": "",
      "href": "",
      "openMode": "same-tab"
    },
    "secondaryCta": {
      "enabled": false,
      "label": "",
      "href": "",
      "openMode": "same-tab"
    },
    "visual": {
      "enabled": false,
      "fill": {
        "type": "none"
      },
      "height": 420,
      "radius": "var(--radius-4xl, 32px)"
    },
    "layout": {
      "variant": "visual-right",
      "maxWidth": 1560,
      "copyWidth": 720,
      "bodyWidth": 720,
      "gap": 80,
      "copyGap": 24
    },
    "behavior": {
      "showBacklink": true,
      "socialShare": {
        "enabled": false
      }
    },
    "stage": {
      "alignment": "center",
      "background": {
        "type": "color",
        "color": "var(--color-system-white)"
      },
      "shadow": {
        "x": 0,
        "y": 0,
        "blur": 0,
        "alpha": 0,
        "color": "#000000",
        "inset": false,
        "spread": 0,
        "enabled": false
      },
      "insideShadow": {
        "linked": true,
        "layer": "below-content",
        "all": {
          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        }
      },
      "canvas": {
        "mode": "wrap",
        "width": 0,
        "height": 0
      },
      "padding": {
        "mobile": {
          "all": 60,
          "top": 60,
          "right": 0,
          "bottom": 60,
          "left": 0,
          "linked": false
        },
        "desktop": {
          "all": 80,
          "top": 80,
          "right": 0,
          "bottom": 80,
          "left": 0,
          "linked": false
        }
      }
    },
    "pod": {
      "widthMode": "full",
      "contentWidth": 1560,
      "radiusLinked": true,
      "radius": "none",
      "radiusTL": "none",
      "radiusTR": "none",
      "radiusBR": "none",
      "radiusBL": "none",
      "background": {
        "type": "color",
        "color": "transparent"
      },
      "shadow": {
        "x": 0,
        "y": 0,
        "blur": 0,
        "alpha": 0,
        "color": "#000000",
        "inset": false,
        "spread": 0,
        "enabled": false
      },
      "insideShadow": {
        "linked": true,
        "layer": "below-content",
        "all": {
          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        }
      },
      "padding": {
        "mobile": {
          "all": 20,
          "top": 0,
          "right": 20,
          "bottom": 0,
          "left": 20,
          "linked": false
        },
        "desktop": {
          "all": 24,
          "top": 0,
          "right": 24,
          "bottom": 0,
          "left": 24,
          "linked": false
        }
      }
    },
    "appearance": {},
    "typography": {
      "roles": {
        "title": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizePreset": "l"
        },
        "body": {
          "color": {
            "type": "color",
            "color": "color-mix(in oklab, var(--color-system-black), transparent 35%)"
          },
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 18,
          "sizePreset": "custom"
        },
        "button": {
          "color": {
            "type": "color",
            "color": "var(--color-system-white)"
          },
          "family": "Inter",
          "weight": "600",
          "fontStyle": "normal",
          "sizeCustom": 16,
          "sizePreset": "custom"
        }
      },
      "globalFamily": "Inter"
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "label": "Copy",
            "nodes": [
              {
                "kind": "field",
                "type": "richtext",
                "path": "headline",
                "label": "Headline",
                "attrs": {
                  "size": "lg"
                }
              },
              {
                "kind": "field",
                "type": "richtext",
                "path": "subheadline",
                "label": "Subheadline",
                "attrs": {
                  "size": "md"
                }
              }
            ]
          },
          {
            "label": "Primary CTA",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "primaryCta.enabled",
                "label": "Show primary CTA",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "text",
                "path": "primaryCta.label",
                "label": "Label"
              },
              {
                "kind": "field",
                "type": "text",
                "path": "primaryCta.href",
                "label": "URL"
              }
            ]
          },
          {
            "label": "Secondary CTA",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "secondaryCta.enabled",
                "label": "Show secondary CTA",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "text",
                "path": "secondaryCta.label",
                "label": "Label"
              },
              {
                "kind": "field",
                "type": "text",
                "path": "secondaryCta.href",
                "label": "URL"
              }
            ]
          },
          {
            "label": "Visual",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "visual.enabled",
                "label": "Show visual",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "dropdown-fill",
                "path": "visual.fill",
                "label": "Visual fill",
                "attrs": {
                  "size": "md",
                  "allow-image": "true",
                  "fill-modes": "color,gradient,image"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "layout",
        "clusters": [
          {
            "label": "Split layout",
            "nodes": [
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "layout.variant",
                "label": "Layout",
                "attrs": {
                  "size": "md",
                  "value": "{{layout.variant}}",
                  "options": [
                    {
                      "label": "Visual right",
                      "value": "visual-right",
                      "icon": "panel.right"
                    },
                    {
                      "label": "Visual left",
                      "value": "visual-left",
                      "icon": "panel.left"
                    },
                    {
                      "label": "Stacked",
                      "value": "stacked",
                      "icon": "panel.top"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.maxWidth",
                "label": "Max width"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.copyWidth",
                "label": "Copy width"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.gap",
                "label": "Split gap"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "visual.height",
                "label": "Visual height"
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          },
          {
            "label": "Behavior",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.showBacklink",
                "label": "Show Made with Clickeen",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.socialShare.enabled",
                "label": "Enable social share",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      }
    ]
  }
}
