{
  "v": 1,
  "widgetname": "cta",
  "itemKey": "cta.item",
  "normalization": {
    "coerceRules": [
      {
        "path": "behavior.showBacklink",
        "type": "boolean",
        "default": true
      },
      {
        "path": "behavior.socialShare.enabled",
        "type": "boolean",
        "default": false
      }
    ]
  },
  "defaults": {
    "header": {
      "enabled": true,
      "title": "Build your next section in minutes",
      "showSubtitle": true,
      "subtitleHtml": "Start with a polished Clickeen widget, customize it in Builder, and publish it anywhere your site needs it.",
      "placement": "top",
      "alignment": "center",
      "gap": 28,
      "textGap": 8,
      "ctaPlacement": "below",
      "innerGap": 18
    },
    "cta": {
      "enabled": true,
      "label": "Get started",
      "href": "#",
      "openMode": "same-tab",
      "iconEnabled": true,
      "iconName": "arrowshape.turn.up.right",
      "iconPlacement": "right"
    },
    "uiLabels": {
      "core": {
        "singular": "CTA",
        "plural": "CTAs",
        "sizeCluster": "CTA size"
      }
    },
    "coreSize": {
      "mode": "auto",
      "fixedHeight": 0,
      "minHeight": 0,
      "preferredVw": 0,
      "maxHeight": 0
    },
    "localeSwitcher": {
      "enabled": false,
      "byIp": false,
      "alwaysShowLocale": "",
      "attachTo": "stage",
      "position": "top-right"
    },
    "behavior": {
      "showBacklink": true,
      "socialShare": {
        "enabled": false
      }
    },
    "stage": {
      "alignment": "center",
      "background": {
        "type": "color",
        "color": "var(--color-system-white)"
      },
      "shadow": {
