  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-appearance"
          },
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          }
        ]
      },
      {
        "id": "settings",
        "clusters": [
          {
            "label": "Clickeen Branding",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.showBacklink",
                "label": "Show Made with Clickeen",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.socialShare.enabled",
                "label": "Enable social share",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
