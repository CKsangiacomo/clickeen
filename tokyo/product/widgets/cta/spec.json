    "typography": {
      "globalFamily": "Inter",
      "roles": {
        "title": {
          "color": "var(--color-system-black)",
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizeCustom": 56,
          "sizePreset": "custom",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1,
          "lineHeightPreset": "custom"
        },
        "body": {
          "color": "var(--color-system-gray)",
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 20,
          "sizePreset": "custom",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.45,
          "lineHeightPreset": "custom"
        },
        "button": {
          "color": "var(--color-system-white)",
          "family": "Inter",
          "weight": "600",
          "fontStyle": "normal",
          "sizeCustom": 16,
          "sizePreset": "custom",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.2,
          "lineHeightPreset": "custom"
        },
        "localeSwitcher": {
          "color": "var(--color-system-black)",
          "family": "Inter",
          "weight": "500",
          "fontStyle": "normal",
          "sizeCustom": 14,
          "sizePreset": "s",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.2,
          "lineHeightPreset": "normal"
        }
      }
