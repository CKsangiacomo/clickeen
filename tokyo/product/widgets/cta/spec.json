        "right": {
          "x": -12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "bottom": {
          "x": 0,
          "y": -12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "left": {
          "x": 12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        }
      },
      "padding": {
        "mobile": {
          "all": 0,
          "top": 0,
          "right": 0,
          "bottom": 0,
          "left": 0,
          "linked": true
        },
        "desktop": {
          "all": 0,
          "top": 0,
          "right": 0,
          "bottom": 0,
          "left": 0,
          "linked": true
        }
      }
    },
    "appearance": {
      "ctaSizePreset": "m",
      "ctaPaddingLinked": false,
      "ctaPaddingInline": 18,
      "ctaPaddingBlock": 12,
      "ctaBackground": "var(--color-system-blue)",
      "ctaTextColor": "var(--color-system-white)",
      "ctaBorder": {
        "enabled": false,
        "width": 1,
        "color": "transparent"
      },
      "ctaRadius": "lg",
      "ctaIconSizePreset": "m",
      "ctaIconSize": 16,
      "localeSwitcherBackground": {
        "type": "color",
        "color": "var(--color-system-white)"
      },
      "localeSwitcherTextColor": {
        "type": "color",
        "color": "var(--color-system-black)"
      },
      "localeSwitcherBorder": {
        "enabled": true,
        "width": 1,
        "color": "var(--color-system-gray-5)"
      },
      "localeSwitcherRadius": "md",
      "localeSwitcherPaddingInline": 12,
      "localeSwitcherPaddingBlock": 8,
      "podBorder": {
        "enabled": false,
        "width": 1,
        "color": "var(--color-system-gray-5)"
      }
