        "alpha": 0,
        "color": "#000000",
        "inset": false,
        "spread": 0,
        "enabled": false
      },
      "insideShadow": {
        "linked": true,
        "layer": "below-content",
        "all": {
          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        },
        "top": {
          "x": 0,
          "y": 12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "right": {
          "x": -12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "bottom": {
          "x": 0,
          "y": -12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "left": {
          "x": 12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        }
      },
      "canvas": {
        "mode": "wrap",
        "width": 0,
        "height": 0
      },
      "padding": {
        "mobile": {
          "all": 48,
          "top": 48,
          "right": 48,
          "bottom": 48,
          "left": 48,
          "linked": true
        },
        "desktop": {
          "all": 80,
          "top": 80,
          "right": 80,
          "bottom": 80,
          "left": 80,
          "linked": true
        }
      }
    },
    "pod": {
      "widthMode": "full",
      "contentWidth": 1200,
      "radiusLinked": true,
      "radius": "none",
      "radiusTL": "none",
      "radiusTR": "none",
      "radiusBR": "none",
      "radiusBL": "none",
      "background": {
        "type": "color",
