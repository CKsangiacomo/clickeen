          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        },
        "top": {
          "x": 0,
          "y": 12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
