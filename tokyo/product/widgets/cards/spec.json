{
  "v": 1,
  "widgetname": "cards",
  "displayName": "Cards",
  "description": "",
  "itemKey": "cards.item",
  "defaults": {
    "uiLabels": {
      "core": {
        "singular": "Card",
        "plural": "Cards",
        "sizeCluster": "Cards size"
      }
    },
    "typography": {
      "roles": {
        "cardTitle": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizeCustom": 24,
          "sizePreset": "m",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.15,
          "lineHeightPreset": "tight"
        },
        "cardCopy": {
          "color": {
            "type": "color",
            "color": "color-mix(in oklab, var(--color-system-black), transparent 28%)"
          },
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 17,
          "sizePreset": "m",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.45,
          "lineHeightPreset": "normal"
        }
      },
      "roleScales": {
        "cardTitle": {
          "l": "28px",
          "m": "24px",
          "s": "20px",
          "xl": "32px",
          "xs": "18px"
        },
        "cardCopy": {
          "l": "19px",
          "m": "17px",
          "s": "15px",
          "xl": "22px",
          "xs": "13px"
        }
      }
    },
    "cards": {
      "appearance": {
        "cardwrapper": {
          "border": {
            "enabled": true,
            "width": 1,
            "color": "var(--color-system-gray-5)"
          },
          "radiusLinked": true,
          "radius": "2xl",
          "radiusTL": "2xl",
          "radiusTR": "2xl",
          "radiusBR": "2xl",
          "radiusBL": "2xl",
          "shadow": {
            "enabled": false,
            "x": 0,
            "y": 0,
            "blur": 0,
            "spread": 0,
            "alpha": 0,
            "color": "#000000",
            "inset": false
          }
        }
      },
      "items": [
        {
          "id": "card-1",
          "title": "Global by default",
          "copy": "Publish once and keep every version aligned from one source of truth.",
          "media": {
            "kind": "icon",
            "iconName": "globe",
            "image": {
              "type": "none"
            },
            "imageAlt": ""
          },
          "link": {
            "enabled": false,
            "href": "#",
            "label": "See details"
          },
          "style": {
            "background": {
              "type": "none"
            },
            "borderColor": {
              "type": "none"
            },
            "accentColor": {
              "type": "none"
            },
            "textTone": "inherit"
          }
        },
        {
          "id": "card-2",
          "title": "Built for pages",
          "copy": "Stack instances into composed pages while each card stays easy to edit.",
          "media": {
            "kind": "icon",
            "iconName": "square.stack.3d.up",
            "image": {
              "type": "none"
            },
            "imageAlt": ""
          },
          "link": {
            "enabled": false,
            "href": "#",
            "label": "See details"
          },
          "style": {
            "background": {
              "type": "none"
            },
            "borderColor": {
              "type": "none"
            },
            "accentColor": {
              "type": "none"
            },
            "textTone": "inherit"
          }
        },
        {
          "id": "card-3",
          "title": "Simple to operate",
          "copy": "Use the same Shell controls for layout, appearance, typography, and publishing.",
          "media": {
            "kind": "icon",
            "iconName": "checkmark",
            "image": {
              "type": "none"
            },
            "imageAlt": ""
          },
          "link": {
            "enabled": false,
            "href": "#",
            "label": "See details"
          },
          "style": {
            "background": {
              "type": "none"
            },
            "borderColor": {
              "type": "none"
            },
            "accentColor": {
              "type": "none"
            },
            "textTone": "inherit"
          }
        }
      ],
      "treatment": "cards",
      "columns": 3,
      "gap": 24,
      "cardPadding": 32,
      "customCardStyles": {
        "enabled": false
      },
      "betweenCards": {
        "enabled": false,
        "kind": "line",
        "line": {
          "widthPt": 2,
          "color": {
            "type": "color",
            "color": "#D7D7DA"
          }
        },
        "icon": {
          "name": "chevron.right",
          "sizePt": 28,
          "color": {
            "type": "color",
            "color": "#222222"
          }
        }
      }
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "label": "Cards",
            "nodes": [
              {
                "kind": "field",
                "type": "repeater",
                "groupId": "content-cards",
                "path": "cards.items",
                "label": "Cards",
                "template": [
                  {
                    "kind": "field",
                    "type": "dropdown-edit",
                    "path": "cards.items.__INDEX__.title",
                    "label": "Card title",
                    "attrs": {
                      "size": "md",
                      "placeholder": "Add card title",
                      "allow-links": "false",
                      "required": true
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-edit",
                    "path": "cards.items.__INDEX__.copy",
                    "label": "Card copy",
                    "attrs": {
                      "size": "md",
                      "placeholder": "Add card copy",
                      "allow-links": "false",
                      "required": true
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-actions",
                    "path": "cards.items.__INDEX__.media.kind",
                    "label": "Media",
                    "attrs": {
                      "size": "md",
                      "options": [
                        {
                          "label": "None",
                          "value": "none"
                        },
                        {
                          "label": "Icon",
                          "value": "icon"
                        },
                        {
                          "label": "Image",
                          "value": "image"
                        }
                      ]
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-actions",
                    "path": "cards.items.__INDEX__.media.iconName",
                    "label": "Card icon",
                    "attrs": {
                      "size": "md",
                      "options": [
                        {
                          "label": "Checkmark",
                          "value": "checkmark"
                        },
                        {
                          "label": "Globe",
                          "value": "globe"
                        },
                        {
                          "label": "Stack",
                          "value": "square.stack.3d.up"
                        },
                        {
                          "label": "Arrow right",
                          "value": "arrow.right"
                        },
                        {
                          "label": "Chevron right",
                          "value": "chevron.right"
                        },
                        {
                          "label": "Arrowshape forward",
                          "value": "arrowshape.forward"
                        },
                        {
                          "label": "Arrowshape turn up right",
                          "value": "arrowshape.turn.up.right"
                        }
                      ]
                    },
                    "showIf": {
                      "path": "cards.items.__INDEX__.media.kind",
                      "op": "equals",
                      "value": "icon"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-fill",
                    "path": "cards.items.__INDEX__.media.image",
                    "label": "Image",
                    "attrs": {
                      "size": "md",
                      "fill-modes": "image",
                      "allow-image": "true"
                    },
                    "showIf": {
                      "path": "cards.items.__INDEX__.media.kind",
                      "op": "equals",
                      "value": "image"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "cards.items.__INDEX__.media.imageAlt",
                    "label": "Image alt text",
                    "showIf": {
                      "path": "cards.items.__INDEX__.media.kind",
                      "op": "equals",
                      "value": "image"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "toggle",
                    "path": "cards.items.__INDEX__.link.enabled",
                    "label": "Enable card link",
                    "attrs": {
                      "size": "md"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "cards.items.__INDEX__.link.href",
                    "label": "Card link URL",
                    "showIf": {
                      "path": "cards.items.__INDEX__.link.enabled",
                      "op": "isTrue"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "cards.items.__INDEX__.link.label",
                    "label": "Card link label",
                    "showIf": {
                      "path": "cards.items.__INDEX__.link.enabled",
                      "op": "isTrue"
                    }
                  }
                ],
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "add-label": "Add card",
                  "remove-label": "Remove card {index}",
                  "move-label": "Move card {index}",
                  "reorder-label": "Manage cards",
                  "reorder-title": "Manage cards",
                  "index-token": "__INDEX__",
                  "min": "2",
                  "max": "16",
                  "default-item": {
                    "id": "",
                    "title": "New card",
                    "copy": "Add supporting copy.",
                    "media": {
                      "kind": "none",
                      "iconName": "checkmark",
                      "imageAlt": ""
                    },
                    "link": {
                      "enabled": false,
                      "href": "#",
                      "label": "Learn more"
                    },
                    "style": {
                      "background": {
                        "type": "none"
                      },
                      "borderColor": {
                        "type": "none"
                      },
                      "accentColor": {
                        "type": "none"
                      },
                      "textTone": "inherit"
                    }
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "core-size"
          },
          {
            "label": "Cards layout",
            "nodes": [
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "cards.treatment",
                "label": "Cards treatment",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Cards",
                      "value": "cards"
                    },
                    {
                      "label": "Linked cards",
                      "value": "linked-cards"
                    },
                    {
                      "label": "Steps",
                      "value": "steps"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "cards.columns",
                "label": "Card columns",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "2",
                      "value": 2
                    },
                    {
                      "label": "3",
                      "value": 3
                    },
                    {
                      "label": "4",
                      "value": 4
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "cards.gap",
                "label": "Card gap",
                "attrs": {
                  "min": 8,
                  "max": 64,
                  "step": 1
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "cards.cardPadding",
                "label": "Card padding",
                "attrs": {
                  "min": 16,
                  "max": 64,
                  "step": 1
                }
              }
            ]
          },
          {
            "label": "Graphic between cards",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "cards.betweenCards.enabled",
                "label": "Graphic between cards",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "dropdown-actions",
                "path": "cards.betweenCards.kind",
                "label": "Graphic type",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Line",
                      "value": "line"
                    },
                    {
                      "label": "Icon",
                      "value": "icon"
                    }
                  ]
                },
                "showIf": {
                  "path": "cards.betweenCards.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "cards.betweenCards.line.widthPt",
                "label": "Line width (pt)",
                "attrs": {
                  "min": 1,
                  "max": 24,
                  "step": 1
                },
                "showIf": {
                  "all": [
                    {
                      "path": "cards.betweenCards.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "cards.betweenCards.kind",
                      "op": "equals",
                      "value": "line"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "dropdown-fill",
                "path": "cards.betweenCards.line.color",
                "label": "Line color",
                "attrs": {
                  "size": "md",
                  "fill-modes": "color",
                  "allow-color": "true"
                },
                "showIf": {
                  "all": [
                    {
                      "path": "cards.betweenCards.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "cards.betweenCards.kind",
                      "op": "equals",
                      "value": "line"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "dropdown-actions",
                "path": "cards.betweenCards.icon.name",
                "label": "Connector icon",
                "attrs": {
                  "size": "md",
                  "options": [
                    {
                      "label": "Checkmark",
                      "value": "checkmark"
                    },
                    {
                      "label": "Arrow right",
                      "value": "arrow.right"
                    },
                    {
                      "label": "Chevron right",
                      "value": "chevron.right"
                    },
                    {
                      "label": "Arrowshape forward",
                      "value": "arrowshape.forward"
                    },
                    {
                      "label": "Arrowshape turn up right",
                      "value": "arrowshape.turn.up.right"
                    }
                  ]
                },
                "showIf": {
                  "all": [
                    {
                      "path": "cards.betweenCards.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "cards.betweenCards.kind",
                      "op": "equals",
                      "value": "icon"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "cards.betweenCards.icon.sizePt",
                "label": "Icon size (pt)",
                "attrs": {
                  "min": 8,
                  "max": 96,
                  "step": 1
                },
                "showIf": {
                  "all": [
                    {
                      "path": "cards.betweenCards.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "cards.betweenCards.kind",
                      "op": "equals",
                      "value": "icon"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "dropdown-fill",
                "path": "cards.betweenCards.icon.color",
                "label": "Icon color",
                "attrs": {
                  "size": "md",
                  "fill-modes": "color",
                  "allow-color": "true"
                },
                "showIf": {
                  "all": [
                    {
                      "path": "cards.betweenCards.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "cards.betweenCards.kind",
                      "op": "equals",
                      "value": "icon"
                    }
                  ]
                }
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-appearance"
          },
          {
            "label": "Card styles",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "path": "cards.customCardStyles.enabled",
                "label": "Custom card styles",
                "attrs": {
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "object-manager",
                "groupId": "appearance-cards",
                "path": "cards.items",
                "template": [
                  {
                    "kind": "field",
                    "type": "dropdown-fill",
                    "path": "cards.items.__INDEX__.style.background",
                    "label": "Card background",
                    "attrs": {
                      "size": "md",
                      "fill-modes": "color",
                      "allow-color": "true"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-fill",
                    "path": "cards.items.__INDEX__.style.borderColor",
                    "label": "Card border color",
                    "attrs": {
                      "size": "md",
                      "fill-modes": "color",
                      "allow-color": "true"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-fill",
                    "path": "cards.items.__INDEX__.style.accentColor",
                    "label": "Card accent color",
                    "attrs": {
                      "size": "md",
                      "fill-modes": "color",
                      "allow-color": "true"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "dropdown-actions",
                    "path": "cards.items.__INDEX__.style.textTone",
                    "label": "Card text tone",
                    "attrs": {
                      "size": "md",
                      "options": [
                        {
                          "label": "Inherit",
                          "value": "inherit"
                        },
                        {
                          "label": "Default",
                          "value": "default"
                        },
                        {
                          "label": "Muted",
                          "value": "muted"
                        },
                        {
                          "label": "Inverse",
                          "value": "inverse"
                        }
                      ]
                    }
                  }
                ],
                "attrs": {
                  "group-label": "",
                  "class": "diet-object-manager",
                  "add-label": "Add card",
                  "reorder-label": "Manage card styles",
                  "reorder-title": "Manage card styles",
                  "label-path": "title",
                  "index-token": "__INDEX__",
                  "allow-structure": "false"
                },
                "showIf": {
                  "path": "cards.customCardStyles.enabled",
                  "op": "isTrue"
                }
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          }
        ]
      },
      {
        "id": "settings",
        "clusters": [
          {
            "kind": "shared",
            "id": "settings-behavior"
          }
        ]
      }
    ]
  }
}
