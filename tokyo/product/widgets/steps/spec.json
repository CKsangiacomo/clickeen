{
  "v": 1,
  "widgetname": "steps",
  "itemKey": "steps.item",
  "normalization": {
    "idRules": [
      {
        "arrayPath": "items",
        "idKey": "id",
        "seedKey": "title",
        "fallbackPrefix": "step"
      }
    ],
    "coerceRules": [
      {
        "path": "behavior.showBacklink",
        "type": "boolean",
        "default": true
      },
      {
        "path": "behavior.socialShare.enabled",
        "type": "boolean",
        "default": false
      }
    ]
  },
  "defaults": {
    "title": "",
    "subhead": "",
    "items": [
      {
        "id": "step-1",
        "title": "",
        "body": "",
        "iconEnabled": false,
        "iconName": ""
      }
    ],
    "layout": {
      "variant": "cards",
      "maxWidth": 1560,
      "columns": 3,
      "rowGap": 80,
      "cardGap": 24,
      "cardPadding": 40
    },
    "appearance": {
      "cardBackground": {
        "type": "color",
        "color": "var(--color-system-gray-5-step5)"
      },
      "cardRadius": "var(--control-radius-4xl)"
    },
    "behavior": {
      "showBacklink": true,
      "socialShare": {
        "enabled": false
      }
    },
    "stage": {
      "alignment": "center",
      "background": {
        "type": "color",
        "color": "var(--color-system-white)"
      },
      "shadow": {
        "x": 0,
        "y": 0,
        "blur": 0,
        "alpha": 0,
        "color": "#000000",
        "inset": false,
        "spread": 0,
        "enabled": false
      },
      "insideShadow": {
        "linked": true,
        "layer": "below-content",
        "all": {
          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        },
        "top": {
          "x": 0,
          "y": 12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "right": {
          "x": -12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "bottom": {
          "x": 0,
          "y": -12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "left": {
          "x": 12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        }
      },
      "canvas": {
        "mode": "wrap",
        "width": 0,
        "height": 0
      },
      "padding": {
        "mobile": {
          "all": 60,
          "top": 60,
          "right": 0,
          "bottom": 60,
          "left": 0,
          "linked": false
        },
        "desktop": {
          "all": 80,
          "top": 80,
          "right": 0,
          "bottom": 80,
          "left": 0,
          "linked": false
        }
      }
    },
    "pod": {
      "widthMode": "full",
      "contentWidth": 1560,
      "radiusLinked": true,
      "radius": "none",
      "radiusTL": "none",
      "radiusTR": "none",
      "radiusBR": "none",
      "radiusBL": "none",
      "background": {
        "type": "color",
        "color": "transparent"
      },
      "shadow": {
        "x": 0,
        "y": 0,
        "blur": 0,
        "alpha": 0,
        "color": "#000000",
        "inset": false,
        "spread": 0,
        "enabled": false
      },
      "insideShadow": {
        "linked": true,
        "layer": "below-content",
        "all": {
          "x": 0,
          "y": 0,
          "blur": 0,
          "alpha": 0,
          "color": "#000000",
          "inset": true,
          "spread": 0,
          "enabled": false
        },
        "top": {
          "x": 0,
          "y": 12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "right": {
          "x": -12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "bottom": {
          "x": 0,
          "y": -12,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        },
        "left": {
          "x": 12,
          "y": 0,
          "blur": 16,
          "alpha": 12,
          "color": "#000000",
          "inset": true,
          "spread": -12,
          "enabled": false
        }
      },
      "padding": {
        "mobile": {
          "all": 20,
          "top": 0,
          "right": 20,
          "bottom": 0,
          "left": 20,
          "linked": false
        },
        "desktop": {
          "all": 24,
          "top": 0,
          "right": 24,
          "bottom": 0,
          "left": 24,
          "linked": false
        }
      }
    },
    "typography": {
      "roles": {
        "title": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizePreset": "l"
        },
        "body": {
          "color": {
            "type": "color",
            "color": "color-mix(in oklab, var(--color-system-black), transparent 35%)"
          },
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 18,
          "sizePreset": "custom"
        },
        "itemTitle": {
          "color": {
            "type": "color",
            "color": "var(--color-system-black)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizeCustom": 28,
          "sizePreset": "custom"
        },
        "itemBody": {
          "color": {
            "type": "color",
            "color": "color-mix(in oklab, var(--color-system-black), transparent 35%)"
          },
          "family": "Inter",
          "weight": "400",
          "fontStyle": "normal",
          "sizeCustom": 18,
          "sizePreset": "custom"
        }
      },
      "roleScales": {
        "itemTitle": {
          "xs": "20px",
          "s": "24px",
          "m": "28px",
          "l": "32px",
          "xl": "36px"
        },
        "itemBody": {
          "xs": "14px",
          "s": "16px",
          "m": "18px",
          "l": "20px",
          "xl": "22px"
        }
      },
      "globalFamily": "Inter"
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "label": "Header",
            "nodes": [
              {
                "kind": "field",
                "type": "textedit",
                "path": "title",
                "label": "Title",
                "attrs": {
                  "size": "lg"
                }
              },
              {
                "kind": "field",
                "type": "textedit",
                "path": "subhead",
                "label": "Subhead",
                "attrs": {
                  "size": "md"
                }
              }
            ]
          },
          {
            "nodes": [
              {
                "kind": "field",
                "type": "object-manager",
                "groupId": "content-steps",
                "path": "items",
                "template": [
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "items.__INDEX__.title",
                    "label": "Title"
                  },
                  {
                    "kind": "field",
                    "type": "textedit",
                    "path": "items.__INDEX__.body",
                    "label": "Body",
                    "attrs": {
                      "size": "md"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "toggle",
                    "path": "items.__INDEX__.iconEnabled",
                    "label": "Show icon",
                    "attrs": {
                      "size": "md"
                    }
                  },
                  {
                    "kind": "field",
                    "type": "textfield",
                    "path": "items.__INDEX__.iconName",
                    "label": "Icon name"
                  }
                ],
                "attrs": {
                  "group-label": "",
                  "class": "diet-object-manager",
                  "add-label": "Add step",
                  "reorder-label": "Manage steps",
                  "reorder-title": "Manage steps",
                  "label-path": "title",
                  "index-token": "__INDEX__",
                  "default-item": {
                    "id": "",
                    "title": "",
                    "body": "",
                    "iconEnabled": false,
                    "iconName": ""
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "id": "layout",
        "clusters": [
          {
            "label": "Steps layout",
            "nodes": [
              {
                "kind": "field",
                "type": "choice-tiles",
                "path": "layout.variant",
                "label": "Variant",
                "attrs": {
                  "size": "md",
                  "value": "{{layout.variant}}",
                  "options": [
                    {
                      "label": "Cards",
                      "value": "cards"
                    },
                    {
                      "label": "Value props",
                      "value": "value-props"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.maxWidth",
                "label": "Max width"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.columns",
                "label": "Columns"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.cardGap",
                "label": "Card gap"
              },
              {
                "kind": "field",
                "type": "valuefield",
                "path": "layout.cardPadding",
                "label": "Card padding"
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
      {
        "id": "appearance",
        "clusters": [
          {
            "label": "Cards",
            "nodes": [
              {
                "kind": "field",
                "type": "dropdown-fill",
                "path": "appearance.cardBackground",
                "label": "Card background",
                "attrs": {
                  "size": "md",
                  "fill-modes": "color,gradient"
                }
              },
              {
                "kind": "field",
                "type": "textfield",
                "path": "appearance.cardRadius",
                "label": "Card radius"
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-appearance"
          },
          {
            "label": "Behavior",
            "nodes": [
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.showBacklink",
                "label": "Show Made with Clickeen",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "type": "toggle",
                "groupId": "settings-behavior",
                "path": "behavior.socialShare.enabled",
                "label": "Enable social share",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      }
    ]
  }
}
