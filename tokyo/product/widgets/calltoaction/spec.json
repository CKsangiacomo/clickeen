              },
              {
                "kind": "field",
                "groupId": "calltoaction-action",
                "type": "valuefield",
                "path": "calltoaction.actionStyle.iconSize",
                "label": "Icon size (px)",
                "attrs": {
                  "group-label": "",
                  "min": 10,
                  "max": 40,
                  "step": 1
