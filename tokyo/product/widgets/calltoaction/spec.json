                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-action",
                "type": "dropdown-border",
                "path": "calltoaction.actionStyle.border",
                "label": "Border",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-action",
                "type": "dropdown-actions",
                "path": "calltoaction.actionStyle.radius",
                "label": "Corner radius",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "None",
                      "value": "none"
                    },
                    {
                      "label": "Small",
                      "value": "sm"
                    },
                    {
                      "label": "Medium",
                      "value": "md"
                    },
                    {
                      "label": "Large",
                      "value": "lg"
                    },
                    {
                      "label": "X-Large",
                      "value": "xl"
                    },
                    {
                      "label": "2XL",
                      "value": "2xl"
                    }
                  ]
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-action",
                "type": "valuefield",
                "path": "calltoaction.actionStyle.paddingInline",
