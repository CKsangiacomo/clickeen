{
  "v": 1,
  "widgetname": "calltoaction",
  "itemKey": "calltoaction.item",
  "defaults": {
    "uiLabels": {
      "core": {
        "singular": "Call to Action",
        "plural": "Calls to Action",
        "sizeCluster": "Call to Action size"
      }
    },
    "typography": {
      "roles": {
        "eyebrow": {
          "color": {
            "type": "color",
            "color": "var(--color-system-gray)"
          },
          "family": "Inter",
          "weight": "700",
          "fontStyle": "normal",
          "sizeCustom": 13,
          "sizePreset": "custom",
          "trackingCustom": 0,
          "trackingPreset": "normal",
          "lineHeightCustom": 1.2,
          "lineHeightPreset": "custom"
        }
      },
      "roleScales": {
        "eyebrow": {
          "l": "16px",
          "m": "13px",
          "s": "12px",
          "xl": "18px",
          "xs": "11px"
        }
      }
    },
    "calltoaction": {
      "showEyebrow": false,
      "eyebrow": "Launch-ready widget",
      "headline": "Build your next section in minutes",
      "showSupportingText": true,
      "supportingTextHtml": "Start with a polished Clickeen widget, customize it in Builder, and publish it anywhere your site needs it.",
      "action": {
        "enabled": true,
        "label": "Get started",
        "href": "#",
        "openMode": "same-tab",
        "iconEnabled": true,
        "iconName": "arrowshape.turn.up.right",
        "iconPlacement": "right"
      },
      "layout": {
        "alignment": "center",
        "gap": 18,
        "textWidth": 760
      },
      "actionStyle": {
        "background": {
          "type": "color",
          "color": "var(--color-system-blue)"
        },
        "textColor": {
          "type": "color",
          "color": "var(--color-system-white)"
        },
        "border": {
          "enabled": false,
          "width": 1,
          "color": "transparent"
        },
        "radius": "lg",
        "paddingInline": 18,
        "paddingBlock": 12,
        "iconSize": 16
      }
    }
  },
  "editor": {
    "panels": [
      {
        "id": "content",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-content"
          },
          {
            "label": "Call to Action content",
            "nodes": [
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "toggle",
                "path": "calltoaction.showEyebrow",
                "label": "Show eyebrow",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "textfield",
                "path": "calltoaction.eyebrow",
                "label": "Eyebrow",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "placeholder": "Add eyebrow text"
                },
                "showIf": {
                  "path": "calltoaction.showEyebrow",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "dropdown-edit",
                "path": "calltoaction.headline",
                "label": "Action headline",
                "attrs": {
                  "group-label": "",
                  "size": "lg",
                  "placeholder": "Add action headline",
                  "allow-links": "false"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "toggle",
                "path": "calltoaction.showSupportingText",
                "label": "Show supporting text",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "dropdown-edit",
                "path": "calltoaction.supportingTextHtml",
                "label": "Supporting text",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "placeholder": "Add supporting copy",
                  "allow-links": "true"
                },
                "showIf": {
                  "path": "calltoaction.showSupportingText",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "toggle",
                "path": "calltoaction.action.enabled",
                "label": "Show action button",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "textfield",
                "path": "calltoaction.action.label",
                "label": "Action label",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "textfield",
                "path": "calltoaction.action.href",
                "label": "Action link",
                "attrs": {
                  "group-label": "",
                  "size": "lg",
                  "placeholder": "https://example.com"
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "dropdown-actions",
                "path": "calltoaction.action.openMode",
                "label": "Open link in",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Same tab",
                      "value": "same-tab"
                    },
                    {
                      "label": "New tab",
                      "value": "new-tab"
                    },
                    {
                      "label": "New window",
                      "value": "new-window"
                    }
                  ]
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "toggle",
                "path": "calltoaction.action.iconEnabled",
                "label": "Show icon",
                "attrs": {
                  "group-label": "",
                  "size": "md"
                },
                "showIf": {
                  "path": "calltoaction.action.enabled",
                  "op": "isTrue"
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "dropdown-actions",
                "path": "calltoaction.action.iconPlacement",
                "label": "Icon position",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Right",
                      "value": "right"
                    }
                  ]
                },
                "showIf": {
                  "all": [
                    {
                      "path": "calltoaction.action.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "calltoaction.action.iconEnabled",
                      "op": "isTrue"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-content",
                "type": "dropdown-actions",
                "path": "calltoaction.action.iconName",
                "label": "Icon",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Checkmark",
                      "value": "checkmark"
                    },
                    {
                      "label": "Arrow right",
                      "value": "arrow.right"
                    },
                    {
                      "label": "Chevron right",
                      "value": "chevron.right"
                    },
                    {
                      "label": "Arrowshape forward",
                      "value": "arrowshape.forward"
                    },
                    {
                      "label": "Arrowshape turn up right",
                      "value": "arrowshape.turn.up.right"
                    }
                  ]
                },
                "showIf": {
                  "all": [
                    {
                      "path": "calltoaction.action.enabled",
                      "op": "isTrue"
                    },
                    {
                      "path": "calltoaction.action.iconEnabled",
                      "op": "isTrue"
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      {
        "id": "typography",
        "shared": {
          "id": "typography"
        }
      },
      {
        "id": "layout",
        "clusters": [
          {
            "kind": "shared",
            "id": "header-layout"
          },
          {
            "kind": "shared",
            "id": "core-size"
          },
          {
            "label": "Call to Action layout",
            "nodes": [
              {
                "kind": "field",
                "groupId": "calltoaction-layout",
                "type": "choice-tiles",
                "path": "calltoaction.layout.alignment",
                "label": "Alignment",
                "attrs": {
                  "group-label": "",
                  "size": "md",
                  "options": [
                    {
                      "label": "Left",
                      "value": "left"
                    },
                    {
                      "label": "Center",
                      "value": "center"
                    },
                    {
                      "label": "Right",
                      "value": "right"
                    }
                  ]
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-layout",
                "type": "valuefield",
                "path": "calltoaction.layout.textWidth",
                "label": "Text width",
                "attrs": {
                  "group-label": "",
                  "min": 280,
                  "max": 1200,
                  "step": 10
                }
              },
              {
                "kind": "field",
                "groupId": "calltoaction-layout",
                "type": "valuefield",
                "path": "calltoaction.layout.gap",
                "label": "Content gap",
                "attrs": {
                  "group-label": "",
                  "min": 0,
                  "max": 80,
                  "step": 1
                }
              }
            ]
          },
          {
            "kind": "shared",
            "id": "stagepod-layout"
          }
        ]
      },
