{
  "name": "@clickeen/devstudio",
  "private": true,
  "version": "0.1.0",
  "description": "Clickeen DevStudio - AI-native integrated development environment",
  "type": "module",
  "scripts": {
    "generate": "node scripts/generate-typography-json.cjs && tsx scripts/generate-component-pages.ts && node scripts/generate-static-registries.mjs",
    "build": "pnpm generate && node scripts/build-static.mjs",
    "check:functions": "find functions -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "lint": "pnpm generate && ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "typecheck": "pnpm generate && tsc --noEmit"
  },
  "keywords": [],
  "author": "Codex AI",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@types/node": "^20.19.19",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "esbuild": "^0.21.5",
    "eslint": "^9.36.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clickeen/ck-contracts": "workspace:*",
    "@clickeen/ck-policy": "workspace:*"
  }
}
