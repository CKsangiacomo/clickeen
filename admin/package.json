{
  "name": "@clickeen/devstudio",
  "private": true,
  "version": "0.1.0",
  "description": "Clickeen DevStudio - AI-native integrated development environment",
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-typography-json.cjs && node scripts/generate-icons-showcase.local.cjs && tsx scripts/generate-component-pages.ts",
    "prebuild": "node scripts/generate-typography-json.cjs && node scripts/generate-icons-showcase.local.cjs && tsx scripts/generate-component-pages.ts",
    "dev": "node --import tsx ./node_modules/vite/bin/vite.js",
    "build": "node --import tsx ./node_modules/vite/bin/vite.js build",
    "check:functions": "find functions -name '*.js' -print0 | xargs -0 -n 1 node --check",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint src --ext .ts",
    "preview": "node --import tsx ./node_modules/vite/bin/vite.js preview",
    "test": "vitest run --config vitest.config.ts --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "Codex AI",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.15.1",
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@types/node": "^20.19.19",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@vitest/browser": "^3.2.4",
    "axe-core": "^4.10.2",
    "eslint": "^9.36.0",
    "glob": "^11.0.3",
    "jsdom": "^26.0.0",
    "tldts": "^6.1.86",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@clickeen/ck-contracts": "workspace:*",
    "@clickeen/ck-policy": "workspace:*",
    "@clickeen/l10n": "workspace:*",
    "gsap": "^3.13.0"
  }
}
